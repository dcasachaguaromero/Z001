UP TO 1 ROWS  FROM T007S INTO TAX_TEXT WHERE
SPRAS = COMP_DATA-SPRAS AND
KALSM = ZKALSM AND
MWSKZ = GS_IT_KOND_TX_W-MWSKZ ORDER BY PRIMARY KEY.

