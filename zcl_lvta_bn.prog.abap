*    SELECT SINGLE LTX INTO L_MES FROM T247 WHERE SPRAS EQ SY-LANGU
*                                             AND MNR   EQ P_MONAT.
*
* NEW CODE
    SELECT LTX
    UP TO 1 ROWS  INTO L_MES FROM T247 WHERE SPRAS EQ SY-LANGU
                                             AND MNR   EQ P_MONAT ORDER BY PRIMARY KEY.

    ENDSELECT.
