           /   P_DIREC,
           107 'Página       :', 122 SY-PAGNO LEFT-JUSTIFIED, /.
    WRITE: /45 'Desde:', FEC1,
            66 'Hasta:', FEC2, /.
  ELSE.
    SKIP 8.
    WRITE: /55 TEXT-001, /.
