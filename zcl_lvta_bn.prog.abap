                                   TABLA-IMPUE
                                   TABLA-IMPUE-5
                                   TABLA-EXPORTA
                                   TABLA-TOTDOC
                                   TABLA-EXENT_MT
                                   TABLA-TOTDOC_MT.
    ENDIF.
    HIDE  TABLA-BELNR.
    CLEAR TABLA-BELNR.
  ENDIF.
