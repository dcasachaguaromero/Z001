*--------------------------------------------------------------------*
*      -->P_SO_FAC  text
*      -->P_1039   text
*--------------------------------------------------------------------*
FORM LOAD_DOC TABLES BLART STRUCTURE SO_FAC
               USING LOW.

  CLEAR BLART.
  BLART-SIGN   = 'I'.
  BLART-OPTION = 'EQ'.
  BLART-LOW    = LOW.
  APPEND BLART.

  RES_VENTAS-BLART = LOW.
* BEGIN. 07-07-2026 - ATC - ATC-01
* OLD CODE
*  SELECT SINGLE LTEXT INTO RES_VENTAS-NOMB FROM T003T
*                                           WHERE SPRAS EQ SY-LANGU
*                                           AND BLART EQ LOW  .
*
* NEW CODE
  SELECT LTEXT
  UP TO 1 ROWS  INTO RES_VENTAS-NOMB FROM T003T
                                           WHERE SPRAS EQ SY-LANGU
                                           AND BLART EQ LOW   ORDER BY PRIMARY KEY.

  ENDSELECT.
* END. 07-07-2026 - ATC - ATC-01
  APPEND RES_VENTAS.

ENDFORM.                    " LOAD_DOC
*&---------------------------------------------------------------------*
*&      Form  CAMB_SIGNO
*&---------------------------------------------------------------------*
form CAMB_SIGNO USING MONTO SIGNO.
CASE SIGNO.
  WHEN  'X'.
    IF MONTO > 0.
      MONTO = MONTO * -1.
    ENDIF.
  WHEN OTHERS.
    IF MONTO < 0.
      MONTO = MONTO * -1.
    ENDIF.
  ENDCASE.

endform.                    " CAMB_SIGNO
