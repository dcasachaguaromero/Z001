                             P_AFECT
                             P_EXENT
                             P_IMPUE
                             P_IMPUE-5
                             P_EXPORTA
                             P_TOTDOC
                             P_EXENT_MT
                             P_TOTDOC_MT.
  DATA: CHAR_AFEC(14),
        CHAR_EXEN(14),
        CHAR_IMPU(14),
