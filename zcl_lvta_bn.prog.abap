FORM RECUP_SOCIEDAD.
  DATA: ZNAME1 LIKE ADRC-NAME1,
        ZNAME2 LIKE ADRC-NAME2,
        ZSTREET LIKE ADRC-STREET,
        ZHOUSE_NUM1 LIKE ADRC-HOUSE_NUM1.

  READ TABLE TABLA INDEX 1.
  SELECT SINGLE ADRC~NAME1 ADRC~NAME2 ADRC~STREET ADRC~HOUSE_NUM1
