*&-------------------------------------------------------------------*
FORM NC_FEERRATAS.

  TABLES:  ZNC_ESPECIAL_BAN.
  CLEAR TABLA.

  SELECT * FROM ZNC_ESPECIAL_BAN.
    IF ZNC_ESPECIAL_BAN-SOCIEDAD   EQ BR_BUKRS-LOW AND
       ZNC_ESPECIAL_BAN-FECHA+0(4) EQ P_GJAHR AND
       ZNC_ESPECIAL_BAN-FECHA+4(2) EQ P_MONAT.

      MOVE ZNC_ESPECIAL_BAN-SOCIEDAD TO TABLA-BUKRS.
      MOVE ZNC_ESPECIAL_BAN-NUMERO   TO TABLA-XBLNR.
      MOVE ZNC_ESPECIAL_BAN-RUT      TO TABLA-STCD1.
      MOVE ZNC_ESPECIAL_BAN-NOMBRE   TO TABLA-NAME1.
      MOVE ZNC_ESPECIAL_BAN-FECHA    TO TABLA-BLDAT.
      MOVE ZNC_ESPECIAL_BAN-BLART    TO TABLA-BLART.
      MOVE ZNC_ESPECIAL_BAN-MONEDA   TO TABLA-WAERS.
      APPEND TABLA.
    ENDIF.
  ENDSELECT.

ENDFORM.                    " nc_feerratas
