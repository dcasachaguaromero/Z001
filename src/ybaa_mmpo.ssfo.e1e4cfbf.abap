
DATA: LV_DRUCKS TYPE C.
CLEAR LV_DRUCKS.
CALL FUNCTION 'MS_READ_LIMIT_FOR_PRINT'
EXPORTING
I_PACKNO          = <FS>-PACKNO
I_ONLINE          = IV_FROM_MEM
IMPORTING
E_ESUH            = GS_ESUH
EXCEPTIONS
NO_LIMIT_TO_PRINT = 1
OTHERS            = 2.

IF SY-SUBRC EQ 0 AND  NOT GS_ESUH-COMMITMENT IS INITIAL.
IF NOT IS_NAST-AENDE IS INITIAL.
"------Print PO Change Info-----------
CALL FUNCTION 'MS_READ_CHANGE_LIMIT'
EXPORTING
I_PACKNO = <FS>-PACKNO
IMPORTING
DRUCK    = LV_DRUCKS.
IF LV_DRUCKS IS INITIAL.  "---No Limit Chg Info---
CLEAR GS_ESUH.
ENDIF.
ENDIF.
ENDIF.


















