
DATA LS_T027B TYPE T027B.
DATA LS_T027A TYPE T027A.
CLEAR GS_V027A.
IF NOT <FS>-EVERS IS INITIAL.
SELECT SINGLE * FROM T027A INTO LS_T027A
WHERE EVERS = <FS>-EVERS.
IF SY-SUBRC = 0.
GS_V027A-EVERS = LS_T027A-EVERS.
GS_V027A-EVDRU = LS_T027A-EVDRU.
ENDIF.

SELECT SINGLE * FROM T027B INTO LS_T027B
WHERE EVERS = <FS>-EVERS
AND SPRAS = GV_LANGUAGE.
IF SY-SUBRC = 0.
GS_V027A-EVTXT = LS_T027B-EVTXT.
ENDIF.
ENDIF.




























