    <item>
     <FUNCNAME>ZF4_ZAHLLAUF</FUNCNAME>
     <SHORT_TEXT>F4 für das Laufdatum und die Laufidentifikation eines Zahllaufs</SHORT_TEXT>
     <IMPORT>
      <RSIMP>
       <PARAMETER>F1TYP</PARAMETER>
       <DEFAULT>&apos;D&apos;</DEFAULT>
       <OPTIONAL>X</OPTIONAL>
       <TYP>C</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>F1NME</PARAMETER>
       <DEFAULT>SPACE</DEFAULT>
       <OPTIONAL>X</OPTIONAL>
       <TYP>C</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>F2NME</PARAMETER>
       <DEFAULT>&apos;F110V-LAUFI&apos;</DEFAULT>
       <OPTIONAL>X</OPTIONAL>
       <TYP>C</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>DISPLAY_LAUFK</PARAMETER>
       <DEFAULT>&apos;X&apos;</DEFAULT>
       <OPTIONAL>X</OPTIONAL>
       <TYP>C</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>EXPLAIN_LAUFK</PARAMETER>
       <DEFAULT>SPACE</DEFAULT>
       <OPTIONAL>X</OPTIONAL>
       <TYP>C</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>BUKRS</PARAMETER>
       <REFERENCE>X</REFERENCE>
       <TYP>BUKRS</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>BANCO</PARAMETER>
       <REFERENCE>X</REFERENCE>
       <TYP>UBNKL</TYP>
      </RSIMP>
     </IMPORT>
     <EXPORT>
      <RSEXP>
       <PARAMETER>LAUFD</PARAMETER>
       <DBFIELD>F110V-LAUFD</DBFIELD>
      </RSEXP>
      <RSEXP>
       <PARAMETER>LAUFI</PARAMETER>
       <DBFIELD>F110V-LAUFI</DBFIELD>
      </RSEXP>
     </EXPORT>
     <TABLES>
      <RSTBL>
       <PARAMETER>LAUFK</PARAMETER>
       <DBSTRUCT>ILAUFK</DBSTRUCT>
       <OPTIONAL>X</OPTIONAL>
      </RSTBL>
     </TABLES>
     <DOCUMENTATION>
      <RSFDO>
       <PARAMETER>F1TYP</PARAMETER>
       <KIND>P</KIND>
      </RSFDO>
