   <LONGTEXTS_ZF4_ZAHLLAUF>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>ZF4_ZAHLLAUF</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0008</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00028</TXTLINES>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZF4_ZAHLLAUF</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00008</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;FUNCTIONALITY&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Wird auf Laufdatum bzw. Laufidentifikation eines Zahlungslaufs die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Werthilfetaste betätigt, so erscheint eine Liste aller Zahlungsläufe</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>mit dem zugehörigen Status. Dazu muß übergeben werden, auf welchem Feld</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>F4 gedrückt wurde (&apos;D&apos; für das Datum, &apos;I&apos; für die Identifikation).</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Ferner ist der Name des Feldes zu übergeben, das ebenfalls versorgt</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>werden soll (also beispielsweise der Name des Feldes für die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Identifikation, wenn der Anwender F4 auf dem Datum gedrückt hat).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Zusätzlich kann bestimmt werden, welche Zahlungsläufe anzeigbar sein</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>sollen. Dabei ist eine Tabelle der Struktur ILAUFK zu füllen, die die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>in den Festwerten der Domäne LAUFK_F110 hinterlegten Werte beinhalten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>kann. (Anmerkung: Die Laufkennung ist die sechste Stelle der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Laufidentifikation.) Durch das Feld SIGN wird analog zu einem Range</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>bestimmt, ob die Laufkennung selektiert oder nicht selektiert werden</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>soll. Ist die Tabelle leer, so werden alle Laufkennungen selektiert.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>F4 auf dem Feld &apos;Laufdatum&apos; des Programms RFCHKN00, auf dem die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Parameter ZW_LAUFI und ZW_LAUFD versorgt werden sollen:</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>CALL FUNCTION &apos;F4_ZAHLLAUF&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>     EXPORTING</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>          F1TYP = &apos;D&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>          F2NME = &apos;ZW_LAUFI&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>     IMPORTING</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>          LAUFD = ZW_LAUFD</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
       <TDLINE>          LAUFI = ZW_LAUFI.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/(</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es gibt keine Ausnahmen. Im Fehlerfall wird die Meldung ausgegeben, daß</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>keine Werte angezeigt werden konnten.</TDLINE>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>ZF4_ZAHLLAUF                  LAUFI</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0002</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00006</TXTLINES>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZF4_ZAHLLAUF                  LAUFI</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00002</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;MEANING&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Wird auf einem der Felder &apos;Laufdatum&apos; oder &apos;Laufidentifikation&apos; die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Werthilfetaste gedrückt, so wird eine Liste aller Zahlungsläufe</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>angezeigt. Nach Auswahl eines LAufs werden beide Felder gefüllt.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;RANGE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;DEFAULT&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS_ZF4_ZAHLLAUF>
