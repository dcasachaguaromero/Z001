MODULE PROC_COMMAND INPUT.
  CASE SY-UCOMM.
  WHEN 'ENTR'.
    SET SCREEN 0.
    LEAVE SCREEN.
  WHEN 'CANC'.
    SET SCREEN 0.
    LEAVE SCREEN.
  ENDCASE.

ENDMODULE.                 " PROC_COMMAND  INPUT
