PARAMETERS P_FILE LIKE RLGRAP-FILENAME.

AT SELECTION-SCREEN ON VALUE-REQUEST FOR P_FILE.

  CALL FUNCTION 'WS_FILENAME_GET'
    EXPORTING
      DEF_FILENAME     = '*.xls*'
      DEF_PATH         = 'C:\'
      MASK             = ',*.txt.'
      MODE             = 'O'
      TITLE            = TEXT-C12
