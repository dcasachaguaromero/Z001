      ADD 1 TO G_REGINDEX.
      PORCENTAJE = ( 100 * G_REGINDEX ) / LIN.
      CLEAR MENSAJE.
      STR_POR = PORCENTAJE.
      CONCATENATE 'Porcentaj de avance del proceso' STR_POR '%' INTO MENSAJE SEPARATED BY SPACE.
      CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
        EXPORTING
          PERCENTAGE = PORCENTAJE
