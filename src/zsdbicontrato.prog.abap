      FILENAME         = P_FILE
    EXCEPTIONS
      INV_WINSYS       = 01
      NO_BATCH         = 02
      SELECTION_CANCEL = 03
      SELECTION_ERROR  = 04.

START-OF-SELECTION.
  DATA STR_FILE TYPE STRING.
  DATA LIN TYPE I.
  DATA PORCENTAJE TYPE I.
  DATA MENSAJE TYPE STRING.

  TYPE-POOLS: TRUXS.
*  DATA: IT_RAW TYPE TRUXS_T_TEXT_DATA.
