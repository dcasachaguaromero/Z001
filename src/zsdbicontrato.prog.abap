      FREE BDCDATA.
      CLEAR BDCDATA.
      PERFORM BDC_DYNPRO USING 'SAPMF02D'           '0100'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'USE_ZAV'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '/00'.
      PERFORM BDC_FIELD  USING 'RF02D-VKORG'        TI_FILE-VKORG.
      PERFORM BDC_FIELD  USING 'RF02D-VTWEG'        TI_FILE-VTWEG.
      PERFORM BDC_FIELD  USING 'RF02D-SPART'        TI_FILE-SPART.
      PERFORM BDC_FIELD  USING 'RF02D-KTOKD'        TI_FILE-KTOKD.
      PERFORM BDC_FIELD  USING 'USE_ZAV'            'X'.

      PERFORM BDC_DYNPRO USING 'SAPMF02D'           '0111'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '/00'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'ADDR1_DATA-COUNTRY'.
      PERFORM BDC_FIELD  USING 'ADDR1_DATA-NAME1'   TI_FILE-NAME1.
      PERFORM BDC_FIELD  USING 'ADDR1_DATA-SORT2'   TI_FILE-SORT2.
      PERFORM BDC_FIELD  USING 'ADDR1_DATA-COUNTRY' TI_FILE-COUNTRY.
      PERFORM BDC_FIELD  USING 'ADDR1_DATA-LANGU'   SY-LANGU.

      PERFORM BDC_DYNPRO USING 'SAPMF02D'           '0310'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'KNVV-WAERS'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '/00'.
      PERFORM BDC_FIELD  USING 'KNVV-WAERS'         'CLP'.

      PERFORM BDC_DYNPRO USING 'SAPMF02D'           '0324'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'KNVP-PARVW(01)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=KLAS'.

      PERFORM BDC_DYNPRO USING 'SAPLCLCA'           '0602'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RMCLF-KLART'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=ENTE'.
      PERFORM BDC_FIELD  USING 'RMCLF-KLART'        '011'.

      PERFORM BDC_DYNPRO USING 'SAPLCLFM'           '0500'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RMCLF-CLASS(01)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '/00'.
      PERFORM BDC_FIELD  USING 'RMCLF-CLASS(01)'    CLASE_CONTRATO.

      PERFORM BDC_DYNPRO USING 'SAPLCTMS'           '0109'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RCTMS-MWERT(10)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=BACK'.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(01)'    'ZFEC_SUSCRIPCION'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(01)'    TI_FILE-FEC_SUS.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(02)'    'ZFEC_CAJA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(02)'    TI_FILE-FEC_CAJ.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(03)'    'ZRUT_VENDEDOR'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(03)'    TI_FILE-RUT_VEN.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(04)'    'ZMONEDA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(04)'    TI_FILE-MONEDA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(05)'    'ZGRUPO_VENTA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(05)'    TI_FILE-GRP_VTA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(06)'    'ZCOMPANIA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(06)'    TI_FILE-COMPANIA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(07)'    'ZMCPA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(07)'    TI_FILE-ZMCPA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(08)'    'ZPACCR'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(08)'    TI_FILE-ZPACCR.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(09)'    'ZBETA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(09)'    TI_FILE-ZBETA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(10)'    'ZMCOB'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(10)'    TI_FILE-ZMCOB.
*
      PERFORM BDC_DYNPRO USING 'SAPLCLFM'           '0500'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RMCLF-CLASS(01)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=AUSW'.
      PERFORM BDC_FIELD  USING 'RMCLF-PAGPOS'       '1'.
      PERFORM BDC_FIELD  USING 'RMCLF-KREUZ(01)'    'X'.

      PERFORM BDC_DYNPRO USING 'SAPLCTMS'           '0109'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RCTMS-MWERT(10)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         'BACK'.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(01)'    'ZOMEGA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(01)'    TI_FILE-ZOMEGA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(02)'    'ZALFA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(02)'    TI_FILE-ZALFA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(03)'    'ZREAJUSTE_IPC'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(03)'    TI_FILE-ZREAJUSTE_IPC.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(04)'    'ZREAJUSTE_TARIFA'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(04)'    TI_FILE-ZREAJUSTE_TARIFA.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(05)'    'ZNUMERO_CONVENIO'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(05)'    TI_FILE-ZNUM_CONVENIO.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(06)'    'ZVERSION_CONVENIO'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(06)'    TI_FILE-ZVER_CONVENIO.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(07)'    'ZRUT_PAGADOR'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(07)'    TI_FILE-ZRUT_PAG.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(08)'    'ZSISTEMA_PAGO'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(08)'    TI_FILE-ZSIS_PAGO.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(09)'    'ZMARCA1'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(09)'    TI_FILE-ZMARCA1.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(10)'    'ZMARCA2'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(10)'    TI_FILE-ZMARCA2.
*
      PERFORM BDC_DYNPRO USING 'SAPLCLFM'           '0500'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RMCLF-CLASS(01)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=AUSW'.
      PERFORM BDC_FIELD  USING 'RMCLF-PAGPOS'       '1'.
      PERFORM BDC_FIELD  USING 'RMCLF-KREUZ(01)'    'X'.

      PERFORM BDC_DYNPRO USING 'SAPLCTMS'           '0109'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RCTMS-MWERT(02)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=BACK'.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(01)'    'ZMARCA3'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(01)'    TI_FILE-ZMARCA3.
*
      PERFORM BDC_FIELD  USING 'RCTMS-MNAME(02)'    'ZTIPO_PLAN'.
      PERFORM BDC_FIELD  USING 'RCTMS-MWERT(02)'    TI_FILE-ZTIPO_PLAN.
*
      PERFORM BDC_DYNPRO USING 'SAPLCLFM'           '0500'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'RMCLF-CLASS(01)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=ENDE'.
      PERFORM BDC_FIELD  USING 'RMCLF-PAGPOS'       '1'.

      PERFORM BDC_DYNPRO USING 'SAPMF02D'           '0324'.
      PERFORM BDC_FIELD  USING 'BDC_CURSOR'         'KNVP-PARVW(01)'.
      PERFORM BDC_FIELD  USING 'BDC_OKCODE'         '=UPDA'.

      FREE MESSTAB.
      CALL TRANSACTION 'XD01' USING BDCDATA
                       MODE   CTUMODE
                       UPDATE CUPDATE
                       MESSAGES INTO MESSTAB.

      CLEAR LS_MESS.
      READ TABLE MESSTAB INTO LS_MESS WITH KEY MSGTYP = 'S'
                                  MSGID = 'F2'
                                  MSGNR = '172'.
      IF SY-SUBRC EQ 0.
        LS_LOG-MSGTYP = LS_MESS-MSGTYP.
        LS_LOG-MSGID = '00'.
        LS_LOG-MSGNR = '398'.
        LS_LOG-MSGV1 = G_REGINDEX .
        CONCATENATE 'El deudor' LS_MESS-MSGV1 INTO LS_LOG-MSGV2 SEPARATED BY SPACE.
        APPEND LS_LOG TO T_LOG.
        PERFORM ACTUALIZAR_TEXTOS USING LS_MESS-MSGV1.
      ELSE.
        READ TABLE MESSTAB INTO LS_MESS WITH KEY MSGTYP = 'E'.
        IF SY-SUBRC NE 0.
          READ TABLE MESSTAB INTO LS_MESS WITH KEY MSGTYP = 'A'.
        ENDIF.
        IF SY-SUBRC EQ 0.
          MESSAGE ID LS_MESS-MSGID TYPE LS_MESS-MSGTYP NUMBER LS_MESS-MSGNR
            INTO L_MESSAGE
            WITH LS_MESS-MSGV1 LS_MESS-MSGV2 LS_MESS-MSGV3 LS_MESS-MSGV4.
          CONDENSE L_MESSAGE.
          LS_LOG-MSGTYP = LS_MESS-MSGTYP.
          LS_LOG-MSGID  = '00'.
          LS_LOG-MSGNR  = '398'.
          LS_LOG-MSGV1  = G_REGINDEX .
          LS_LOG-MSGV2  = L_MESSAGE(100).
          LS_LOG-MSGV3  = L_MESSAGE+100(100).
          APPEND LS_LOG TO T_LOG.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.

END-OF-SELECTION.
  IF T_LOG IS NOT INITIAL.
    PERFORM DISPLAY_LOG.
  ENDIF.

*----------------------------------------------------------------------*
*        Start new screen                                              *
*----------------------------------------------------------------------*
FORM BDC_DYNPRO USING PROGRAM DYNPRO.
  CLEAR LS_BDC.
  LS_BDC-PROGRAM  = PROGRAM.
  LS_BDC-DYNPRO   = DYNPRO.
  LS_BDC-DYNBEGIN = 'X'.
  APPEND LS_BDC TO BDCDATA.
ENDFORM.                    "BDC_DYNPRO

*----------------------------------------------------------------------*
*        Insert field                                                  *
*----------------------------------------------------------------------*
FORM BDC_FIELD USING FNAM FVAL.

  CLEAR LS_BDC.
  LS_BDC-FNAM = FNAM.
  LS_BDC-FVAL = FVAL.
  APPEND LS_BDC TO BDCDATA.

ENDFORM.                    "BDC_FIELD
*&---------------------------------------------------------------------*
*&      Form  ACTUALIZAR_TEXTOS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM ACTUALIZAR_TEXTOS USING CONTRATO.

  CLEAR GS_THEAD.
  CLEAR GS_LINES.
  REFRESH T_LINES.

  GS_THEAD-TDOBJECT = 'KNA1'.
  GS_THEAD-TDNAME   = CONTRATO.
  GS_THEAD-TDID     = 'Z001'.
  GS_THEAD-TDSPRAS  = SY-LANGU.

*  GS_LINES-TDFORMAT = '*'.
*  GS_LINES-TDLINE   = WA_DATA-TEXTO1.
*  APPEND GS_LINES TO T_LINES.

  CALL FUNCTION 'SAVE_TEXT'
    EXPORTING
      HEADER          = GS_THEAD
      SAVEMODE_DIRECT = 'X'
    TABLES
      LINES           = T_LINES
    EXCEPTIONS
      ID              = 1
      LANGUAGE        = 2
      NAME            = 3
      OBJECT          = 4
      OTHERS          = 5.

  IF SY-SUBRC <> 0.
    PERFORM ADD_SY_MESS_TO_LOG.
  ELSE.
    LS_LOG-MSGTYP = 'I'.
    LS_LOG-MSGID = '00'.
    LS_LOG-MSGNR = '398'.
    LS_LOG-MSGV1 = G_REGINDEX .
    LS_LOG-MSGV2 = 'Texto1 Cliente'.
    LS_LOG-MSGV3 = CONTRATO.
    LS_LOG-MSGV4 = 'actualizado con exito'.
    APPEND LS_LOG TO T_LOG.
  ENDIF.

ENDFORM.                    " ACTUALIZAR_TEXTOS
*&---------------------------------------------------------------------*
*&      Form  ADD_SY_MESS_TO_LOG
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM ADD_SY_MESS_TO_LOG .

  LS_LOG-MSGTYP  = SY-MSGTY.
  LS_LOG-MSGSPRA = SY-LANGU.
  LS_LOG-MSGID   =  SY-MSGID.
  LS_LOG-MSGNR   = SY-MSGNO.
  LS_LOG-MSGV1   = SY-MSGV1.
  LS_LOG-MSGV2   = SY-MSGV2.
  LS_LOG-MSGV3   = SY-MSGV3.
  LS_LOG-MSGV4   =  SY-MSGV3.
  APPEND  LS_LOG TO T_LOG.

ENDFORM.                    " ADD_SY_MESS_TO_LOG
*&---------------------------------------------------------------------*
*&      Form  DISPLAY_LOG
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM DISPLAY_LOG .

  DATA: LS_HEADER     TYPE BALHDRI,
        LF_LOG_HANDLE TYPE BALLOGHNDL,
        LF_LOG_NUMBER TYPE BALOGNR,
        LT_MSG        TYPE BALMI_TAB,
        LS_MSG        TYPE BALMI,
        LT_LOGNUM     TYPE TABLE OF BALNRI,
        LS_LOGNUM     TYPE BALNRI.
*
  LS_HEADER-OBJECT     = 'ZSD_LOG'.
  LS_HEADER-SUBOBJECT  = 'Z03'.
  LS_HEADER-ALDATE     = SY-DATUM.
  LS_HEADER-ALTIME     = SY-UZEIT.
  LS_HEADER-ALUSER     = SY-UNAME.
  LS_HEADER-ALDATE_DEL = SY-DATUM + 1.
*
  CALL FUNCTION 'APPL_LOG_WRITE_HEADER'
    EXPORTING
      HEADER              = LS_HEADER
    IMPORTING
      E_LOG_HANDLE        = LF_LOG_HANDLE
    EXCEPTIONS
      OBJECT_NOT_FOUND    = 1
      SUBOBJECT_NOT_FOUND = 2
      ERROR               = 3
      OTHERS              = 4.
  IF SY-SUBRC <> 0.
    MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
            WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.

  CALL FUNCTION 'BAL_DB_LOGNUMBER_GET'
    EXPORTING
      I_CLIENT                 = SY-MANDT
      I_LOG_HANDLE             = LF_LOG_HANDLE
    IMPORTING
      E_LOGNUMBER              = LF_LOG_NUMBER
    EXCEPTIONS
      LOG_NOT_FOUND            = 1
      LOGNUMBER_ALREADY_EXISTS = 2
      NUMBERING_ERROR          = 3
      OTHERS                   = 4.
*
  LOOP AT T_LOG INTO LS_MESS.
    MOVE-CORRESPONDING LS_MESS TO LS_MSG.
    MOVE: LS_MESS-MSGTYP TO LS_MSG-MSGTY,
          LS_MESS-MSGNR  TO LS_MSG-MSGNO.
    LS_MSG-MSGV2 = LS_MESS-MSGV2(50).
    LS_MSG-MSGV3 = LS_MESS-MSGV2+50(50).
    APPEND LS_MSG TO LT_MSG.
  ENDLOOP.

  CALL FUNCTION 'APPL_LOG_WRITE_MESSAGES'
    EXPORTING
      OBJECT              = LS_HEADER-OBJECT
      SUBOBJECT           = LS_HEADER-SUBOBJECT
      LOG_HANDLE          = LF_LOG_HANDLE
    TABLES
      MESSAGES            = LT_MSG[]
    EXCEPTIONS
      OBJECT_NOT_FOUND    = 1
      SUBOBJECT_NOT_FOUND = 2
      OTHERS              = 3.
  IF SY-SUBRC <> 0.
    MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
            WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.
  CALL FUNCTION 'BAL_DSP_LOG_DISPLAY'.

ENDFORM.                    " DISPLAY_LOG
