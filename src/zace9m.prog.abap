    PERFORM C1 USING '                               ''C'' TXTSTR.'.
    PERFORM C1 USING '        EXIT.'.
    PERFORM C1 USING '      ENDIF.'.
    PERFORM C1 USING '    ENDIF.'.
    PERFORM C1 USING '  ENDLOOP.'.
  ELSE.
    PERFORM C1 USING '  SELECT COMPONENT'.
