*---------------------------------------------------------------------*
*       FORM DIRECTORYANDJOBTEST                                      *
*---------------------------------------------------------------------*
FORM DIRECTORYANDJOBTEST.

* Prevent user from running ABAP if they are below version 4.7
  IF SY-SAPRL < '620'.
    MESSAGE ID 'AD' TYPE 'E' NUMBER 10
                         WITH 'This version of SAP is not supported by'
                              'ACE-S'.
  ENDIF.

* Create a batch job if in dialog mode
  IF SY-BATCH IS INITIAL.
    PERFORM VALIDATIONCHECK.
    PERFORM CREATEBATCHJOB.
    EXIT.
  ENDIF.

* Do server directory check
  PERFORM DIRECTORYCHECK.
ENDFORM.                    "DIRECTORYANDJOBTEST

*---------------------------------------------------------------------*
*       FORM DIRECTORYCHECK                                           *
*---------------------------------------------------------------------*
FORM DIRECTORYCHECK.
  DATA: PATH TYPE EPSF-EPSDIRNAM
       ,MASK LIKE EPSF-EPSFILNAM
       ,COUNT TYPE I
       ,TXTSTR TYPE STRING
       ,ISTRING TYPE TABLE OF STRING
       ,DISKSPACE TYPE F
       ,FILESYS LIKE OPSYSTEM-FILESYS
       ,IFILES TYPE TABLE OF EPSFILI
       ,ACTVT LIKE AUTHB-ACTVT VALUE 34
       ,OPENMODE(2) VALUE 'W'
       ,PROGRAM LIKE  AUTHB-PROGRAM
       ,AUTHPATH LIKE AUTHB-FILENAME.

  DATA: BEGIN OF ITABL OCCURS 0
       ,LINE(5000)
       ,END OF ITABL.

  FIELD-SYMBOLS: <ZSTRING> TYPE STRING
                ,<ZLINE> LIKE LINE OF ITABL.

  CONSTANTS: LC_REQUIREDSPACE TYPE I VALUE 1229. "1.2 GB

  CONCATENATE '??????' FEXT INTO MASK.

  WBATCHLOG-TYPE = 'I'.

* Info messages.
  CONCATENATE 'Information: OS:' SY-OPSYS
     INTO TXTSTR SEPARATED BY SPACE.
  WBATCHLOG-MESSAGE = TXTSTR.
  APPEND WBATCHLOG TO IBATCHLOG.
  MESSAGE TXTSTR TYPE 'S'.

  CONCATENATE 'Information: Current Server:' SERVER
    INTO TXTSTR SEPARATED BY SPACE.
  WBATCHLOG-MESSAGE = TXTSTR.
  APPEND WBATCHLOG TO IBATCHLOG.
  MESSAGE TXTSTR TYPE 'S'.

  CONCATENATE 'Information: Batch Server:' PSERVER
     INTO TXTSTR SEPARATED BY SPACE.
  WBATCHLOG-MESSAGE = TXTSTR.
  APPEND WBATCHLOG TO IBATCHLOG.
  MESSAGE TXTSTR TYPE 'S'.

  CONCATENATE 'Information: Path:' PPATH
     INTO TXTSTR SEPARATED BY SPACE.
  WBATCHLOG-MESSAGE = TXTSTR.
  APPEND WBATCHLOG TO IBATCHLOG.
  MESSAGE TXTSTR TYPE 'S'.

* Directory Check & File Exists
  PATH = PPATH.
  CALL FUNCTION 'EPS_GET_DIRECTORY_LISTING'
    EXPORTING
      DIR_NAME                     = PATH
      FILE_MASK                    = MASK
    TABLES
      DIR_LIST                     = IFILES
    EXCEPTIONS
      INVALID_EPS_SUBDIR           = 1
      SAPGPARAM_FAILED             = 2
      BUILD_DIRECTORY_FAILED       = 3
      NO_AUTHORIZATION             = 4
      READ_DIRECTORY_FAILED        = 5
      TOO_MANY_READ_ERRORS         = 6
      EMPTY_DIRECTORY_LIST         = 7
      OTHERS                       = 8.
  IF SY-SUBRC <> 0 AND SY-SUBRC <> 7.           "Could be empty folder
    CASE SY-SUBRC.
      WHEN 4.
        CONCATENATE 'DIR CHECK: No auth to get file list of' PATH
          INTO TXTSTR SEPARATED BY SPACE.
      WHEN 5.
        CONCATENATE 'DIR CHECK: Failed to access path''' PATH
                    '''on server <' PSERVER '>'
          INTO TXTSTR SEPARATED BY SPACE.
      WHEN OTHERS.
        TXT2STR = SY-SUBRC.
        CONCATENATE 'DIR CHECK: E:' TXT2STR
          INTO TXTSTR SEPARATED BY SPACE.
    ENDCASE.
    PERFORM PROCESSBATCHERROR USING TXTSTR.
  ENDIF.

  DESCRIBE TABLE IFILES LINES COUNT.
  IF COUNT GT 0.
    CONCATENATE 'There are already files ending with .XJF in directory'
                '''' PPATH ''' on server <' PSERVER '>'
      INTO TXTSTR SEPARATED BY SPACE.
    PERFORM PROCESSBATCHERROR USING TXTSTR.
  ENDIF.

* Check disk space available
  SELECT SINGLE FILESYS FROM OPSYSTEM INTO FILESYS
    WHERE OPSYS = SY-OPSYS.

  IF FILESYS = 'WINDOWS NT'
    OR FILESYS = 'DOS'
    OR FILESYS = 'UNIX'.
  TRY .
      CASE FILESYS.
        WHEN 'WINDOWS NT' OR 'DOS'.
          CONCATENATE 'Dir' PPATH INTO COMMAND SEPARATED BY SPACE.

          PERFORM RUNCOMMAND CHANGING ITABL[].

          DESCRIBE TABLE ITABL LINES COUNT.
          "Get last line of table
          READ TABLE ITABL INDEX COUNT ASSIGNING <ZLINE>.
          IF SY-SUBRC = 0.
            "Split the line to enable reading values
            SPLIT <ZLINE>(1000) AT SPACE INTO TABLE ISTRING.
          ENDIF.

          IF ISTRING IS NOT INITIAL.
            DESCRIBE TABLE ISTRING LINES COUNT.
            COUNT = COUNT - 2. "< 3rd last line
            READ TABLE ISTRING INDEX COUNT ASSIGNING <ZSTRING>.
            IF <ZSTRING> IS ASSIGNED.
              " Get rid of any comma's
              TRANSLATE <ZSTRING> USING ', '.
              " Get rid of any #'s
              TRANSLATE <ZSTRING> USING '# '.
              " Get rid of any ÿ's
              TRANSLATE <ZSTRING> USING 'ÿ '.
              CONDENSE <ZSTRING> NO-GAPS.

              DISKSPACE = <ZSTRING>.
              DISKSPACE = DISKSPACE / 1024 / 1024.

              IF DISKSPACE LT LC_REQUIREDSPACE.
                CONCATENATE 'There is not enough space in directory'
                            ' ''' PPATH ''' on server <' PSERVER '>'
                  INTO TXTSTR.
                PERFORM PROCESSBATCHERROR USING TXTSTR.
              ENDIF.
            ENDIF.
          ENDIF.
        WHEN 'UNIX'.
          CONCATENATE 'df -k' PPATH INTO COMMAND SEPARATED BY SPACE.
          PERFORM RUNCOMMAND CHANGING ITABL[].
          LOOP AT ITABL ASSIGNING <ZLINE>.
            CONCATENATE 'UNIX: ' <ZLINE>
              INTO TXTSTR SEPARATED BY SPACE.
            WBATCHLOG-TYPE = 'I'.
            WBATCHLOG-MESSAGE = TXTSTR.
            APPEND WBATCHLOG TO IBATCHLOG.
          ENDLOOP.
      ENDCASE.

    CATCH CX_SY_CONVERSION_OVERFLOW  CX_SY_CONVERSION_NO_NUMBER.
      IF <ZSTRING> IS ASSIGNED.
        CONCATENATE 'Could not calculate disk space correctly using'
                    ' value: ''' <ZSTRING> ''''
          INTO TXTSTR.
      ELSE.
        CONCATENATE 'Could not calculate disk space correctly.'
                    ''
          INTO TXTSTR.
      ENDIF.
      WBATCHLOG-TYPE = 'I'.
      WBATCHLOG-MESSAGE = TXTSTR.
      APPEND WBATCHLOG TO IBATCHLOG.
      MESSAGE TXTSTR TYPE 'S'.
  ENDTRY.

  ENDIF.

* Check if user has write access
  CASE FILESYS.
    WHEN 'WINDOWS NT' OR 'DOS'.
      CONCATENATE PPATH '\' '__' PSERVER SY-DATUM SY-UZEIT SY-UNAME
        INTO AUTHPATH.
    WHEN OTHERS.
      CONCATENATE PPATH '/' '__' PSERVER SY-DATUM SY-UZEIT SY-UNAME
        INTO AUTHPATH.
  ENDCASE.

  IF PROGRAM IS INITIAL.
    CALL 'AB_GET_CALLER' ID 'PROGRAM' FIELD PROGRAM.
  ENDIF.

  " Check authorisation
  AUTHORITY-CHECK OBJECT 'S_DATASET'
    ID 'PROGRAM'  FIELD PROGRAM
    ID 'ACTVT'    FIELD ACTVT
    ID 'FILENAME' FIELD AUTHPATH.                          "#EC *

  IF SY-SUBRC NE 0.
    CONCATENATE 'SAP does not have the right to write files'
                'in directory ''' PPATH ''' on server <' PSERVER '>'
      INTO TXTSTR.
    PERFORM PROCESSBATCHERROR USING TXTSTR.
  ENDIF.

  OPEN DATASET AUTHPATH FOR OUTPUT IN BINARY MODE
    MESSAGE TXTSTR.
  IF SY-SUBRC NE 0.
    CONCATENATE 'SAP does not have permissions to write files'
                'to directory''' PPATH '''on server <' PSERVER '>.'
                'OS Error:' TXTSTR
      INTO TXTSTR SEPARATED BY SPACE.
    PERFORM PROCESSBATCHERROR USING TXTSTR.
  ELSE.
    DELETE DATASET AUTHPATH.
  ENDIF.

  WBATCHLOG-TYPE = 'I'.
  WBATCHLOG-MESSAGE = 'Information: Directory check complete'.
  APPEND WBATCHLOG TO IBATCHLOG.
  MESSAGE 'Directory check complete' TYPE 'I'.

ENDFORM.                    "DIRECTORYCHECK

*---------------------------------------------------------------------*
*       FORM RUNCOMMAND                                               *
*---------------------------------------------------------------------*
FORM RUNCOMMAND CHANGING ITABL TYPE ANY TABLE.

  CALL 'SYSTEM'
    ID 'COMMAND' FIELD COMMAND
    ID 'TAB' FIELD ITABL.

ENDFORM.                    "RUNCOMMAND

*---------------------------------------------------------------------*
*       FORM CREATEVARIANT                                            *
*---------------------------------------------------------------------*
FORM CREATEVARIANT.

  DATA: BEGIN OF IRSPARAMS OCCURS 10.
          INCLUDE STRUCTURE RSPARAMS.
  DATA: END OF IRSPARAMS.
  DATA: BEGIN OF IVARID.
          INCLUDE STRUCTURE VARID.
  DATA: END OF IVARID.
  DATA: BEGIN OF IVARIT OCCURS 2.
          INCLUDE STRUCTURE VARIT.
  DATA: END OF IVARIT.
  DATA: RC TYPE SYST-SUBRC.

* Tabellen initialisieren
  CLEAR: IVARID.
  REFRESH IVARIT.
  REFRESH IRSPARAMS.

* Fill VARID structure - variant description
  IVARID-REPORT  = SY-REPID.
  IVARID-VARIANT = '@STD'.
  IVARID-ENVIRONMNT = 'A'.

* Fill VARIT structure - variant texts
  IVARIT-MANDT   = SY-MANDT.
  IVARIT-LANGU   = SY-LANGU.
  IVARIT-REPORT  = SY-REPID.
  IVARIT-VARIANT = IVARID-VARIANT.
  IVARIT-VTEXT   = '@STD'.
  APPEND IVARIT.

* Fill RSPARAMS structure - Selektionswerte; variant contents
  CALL FUNCTION 'RS_REFRESH_FROM_SELECTOPTIONS'
    EXPORTING
      CURR_REPORT           = SY-REPID
    TABLES
      SELECTION_TABLE       = IRSPARAMS
   EXCEPTIONS
     NOT_FOUND             = 1
     NO_REPORT             = 2
     OTHERS                = 3
            .
  IF SY-SUBRC <> 0.
    MESSAGE 'Unable to retrieve screen parameters.' TYPE 'I'
      DISPLAY LIKE 'E'.
  ENDIF.

*Check variant
  CALL FUNCTION 'RS_VARIANT_EXISTS'
    EXPORTING
      REPORT              = IVARID-REPORT
      VARIANT             = IVARID-VARIANT
    IMPORTING
      R_C                 = RC
    EXCEPTIONS
      NOT_AUTHORIZED      = 01
      NO_REPORT           = 02
      REPORT_NOT_EXISTENT = 03
      REPORT_NOT_SUPPLIED = 04.
  IF SY-SUBRC <> 0.
    TXT2STR = SY-SUBRC.
    CONCATENATE 'Check variant exists error:'
                'E:' TXT2STR
      INTO TXTSTR SEPARATED BY SPACE.
    MESSAGE TXTSTR TYPE 'E' DISPLAY LIKE 'S'.
  ENDIF.

  IF RC = 0.                    " Variante existiert
    CALL FUNCTION 'RS_CHANGE_CREATED_VARIANT'
      EXPORTING
        CURR_REPORT               = IVARID-REPORT
        CURR_VARIANT              = IVARID-VARIANT
        VARI_DESC                 = IVARID
      TABLES
        VARI_CONTENTS             = IRSPARAMS
        VARI_TEXT                 = IVARIT
      EXCEPTIONS
        ILLEGAL_REPORT_OR_VARIANT = 01
        ILLEGAL_VARIANTNAME       = 02
        NOT_AUTHORIZED            = 03
        NOT_EXECUTED              = 04
        REPORT_NOT_EXISTENT       = 05
        REPORT_NOT_SUPPLIED       = 06
        VARIANT_DOESNT_EXIST      = 07
        VARIANT_LOCKED            = 08
        SELECTIONS_NO_MATCH       = 09.
    IF SY-SUBRC <> 0.
      TXT2STR = SY-SUBRC.
      CONCATENATE 'Change variant error:'
                  'E:' TXT2STR
        INTO TXTSTR SEPARATED BY SPACE.
      MESSAGE TXTSTR TYPE 'E' DISPLAY LIKE 'S'.
    ENDIF.
  ELSE.
    CALL FUNCTION 'RS_CREATE_VARIANT'
      EXPORTING
        CURR_REPORT               = IVARID-REPORT
        CURR_VARIANT              = IVARID-VARIANT
        VARI_DESC                 = IVARID
      TABLES
        VARI_CONTENTS             = IRSPARAMS
        VARI_TEXT                 = IVARIT
      EXCEPTIONS
        ILLEGAL_REPORT_OR_VARIANT = 01
        ILLEGAL_VARIANTNAME       = 02
        NOT_AUTHORIZED            = 03
        NOT_EXECUTED              = 04
        REPORT_NOT_EXISTENT       = 05
        REPORT_NOT_SUPPLIED       = 06
        VARIANT_EXISTS            = 07
        VARIANT_LOCKED            = 08.
    IF SY-SUBRC <> 0.
      TXT2STR = SY-SUBRC.
      CONCATENATE 'Create variant error:'
                  'E:' TXT2STR
        INTO TXTSTR SEPARATED BY SPACE.
      MESSAGE TXTSTR TYPE 'E' DISPLAY LIKE 'S'.
    ENDIF.
  ENDIF.
  RC = SY-SUBRC.
ENDFORM.                    "CREATEVARIANT

*---------------------------------------------------------------------*
*       FORM VALIDATIONCHECK                                          *
*---------------------------------------------------------------------*
FORM VALIDATIONCHECK.

* Check that a path has been entered
  IF PPATH = ''
   OR PPATH = 'Please enter a valid path to an empty directory.'.
    MESSAGE ID 'AD' TYPE 'I' NUMBER 10
                         WITH 'Fill in Path'
                         DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

* Check that an application server has been selected
  IF PSERVER EQ ''.
    MESSAGE ID 'AD' TYPE 'I' NUMBER 10
                         WITH 'Please select an application server'
                              'to run ACE'
                         DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

  IF UCOMM <> 'BUT1' AND PBTCIMM = ' ' AND PBTCDATE IS INITIAL.
    MESSAGE ID 'AD' TYPE 'I' NUMBER 10
                         WITH 'Parameter to run immediately'
                              'or date is not set'
                         DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

ENDFORM.                    "VALIDATIONCHECK

*---------------------------------------------------------------------*
*       FORM CREATEBATCHJOB                                           *
*---------------------------------------------------------------------*
FORM CREATEBATCHJOB.
  DATA: JOBCOUNT TYPE TBTCJOB-JOBCOUNT,
        JOBNAME TYPE TBTCJOB-JOBNAME,
        CLASS TYPE TBTCJOB-JOBGROUP,
        ERROR TYPE STRING,
        APPSERVER TYPE BTCTGTSRVR-SRVNAME,
        BTC_DATE  TYPE TBTCJOB-SDLSTRTDT,
        BTC_TIME  TYPE TBTCJOB-SDLSTRTTM.

  IF PBTCIMM = ' '.
    BTC_DATE = PBTCDATE.
    BTC_TIME = PBTCTIME.
  ENDIF.

* Setup the class
  CLASS = PBTCCLAS.

* Setup the jobname (and create variant if executing)
  IF UCOMM EQ 'BUT1'.
    CONCATENATE SY-REPID PSERVER INTO JOBNAME SEPARATED BY '_'.
  ELSE.
    JOBNAME = PBTCJOB.
    PERFORM CREATEVARIANT.
  ENDIF.

  TRANSLATE JOBNAME TO UPPER CASE.

* Job open
  CALL FUNCTION 'JOB_OPEN'
    EXPORTING
      DELANFREP        = ' '
      JOBGROUP         = CLASS
      JOBNAME          = JOBNAME
      SDLSTRTDT        = BTC_DATE
      SDLSTRTTM        = BTC_TIME
    IMPORTING
      JOBCOUNT         = JOBCOUNT
    EXCEPTIONS
      CANT_CREATE_JOB  = 01
      INVALID_JOB_DATA = 02
      JOBNAME_MISSING  = 03.

  IF SY-SUBRC <> 0.
    CONCATENATE 'Error scheduling job' JOBNAME INTO ERROR
      SEPARATED BY SPACE.
    MESSAGE ERROR TYPE 'I' DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

* run the program as a step
  IF UCOMM EQ 'BUT1'.
    SUBMIT (SY-REPID) WITH AJOB     = JOBNAME
                      WITH PSERVER  = PSERVER
                      WITH PBTCCLAS = PBTCCLAS
                      WITH PBTCIMM  = 'X'
                      WITH PBTCDATE = SPACE
                      WITH PBTCUSER = PBTCUSER
                      WITH PPATH    = PPATH
                      WITH PBTCTEST = 'X'
      VIA JOB JOBNAME NUMBER JOBCOUNT
      AND RETURN.
  ELSE.
    CALL FUNCTION 'JOB_SUBMIT'
      EXPORTING
        AUTHCKNAM               = PBTCUSER
        JOBCOUNT                = JOBCOUNT
        JOBNAME                 = JOBNAME
        REPORT                  = SY-REPID
        VARIANT                 = '@STD'
      EXCEPTIONS
        BAD_PRIPARAMS           = 1
        BAD_XPGFLAGS            = 2
        INVALID_JOBDATA         = 3
        JOBNAME_MISSING         = 4
        JOB_NOTEX               = 5
        JOB_SUBMIT_FAILED       = 6
        LOCK_FAILED             = 7
        PROGRAM_MISSING         = 8
        PROG_ABAP_AND_EXTPG_SET = 9
        OTHERS                  = 10.
  ENDIF.

  APPSERVER = PSERVER.
  IF PBTCIMM = 'X' OR UCOMM EQ 'BUT1'.
*   run the job immediately
    CALL FUNCTION 'JOB_CLOSE'
      EXPORTING
        JOBCOUNT             = JOBCOUNT
        JOBNAME              = JOBNAME
        STRTIMMED            = 'X'
        TARGETSERVER         = APPSERVER
      EXCEPTIONS
        CANT_START_IMMEDIATE = 1
        INVALID_STARTDATE    = 2
        JOBNAME_MISSING      = 3
        JOB_CLOSE_FAILED     = 4
        JOB_NOSTEPS          = 5
        JOB_NOTEX            = 6
        LOCK_FAILED          = 7
        INVALID_TARGET       = 8
        OTHERS               = 9.
  ELSE.
*   schedule job
    CALL FUNCTION 'JOB_CLOSE'
      EXPORTING
        JOBCOUNT             = JOBCOUNT
        JOBNAME              = JOBNAME
        SDLSTRTDT            = BTC_DATE
        SDLSTRTTM            = BTC_TIME
        TARGETSERVER         = APPSERVER
      EXCEPTIONS
        CANT_START_IMMEDIATE = 1
        INVALID_STARTDATE    = 2
        JOBNAME_MISSING      = 3
        JOB_CLOSE_FAILED     = 4
        JOB_NOSTEPS          = 5
        JOB_NOTEX            = 6
        LOCK_FAILED          = 7
        INVALID_TARGET       = 8
        OTHERS               = 9.
  ENDIF.

  IF SY-SUBRC <> 0.
    CONCATENATE 'Error scheduling job' JOBNAME INTO ERROR
      SEPARATED BY SPACE.
    MESSAGE ERROR TYPE 'I' DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

* commit the changes to the database
  COMMIT WORK AND WAIT.

  IF UCOMM EQ 'BUT1'.
    PERFORM CHECKBATCHJOB USING JOBCOUNT
                                JOBNAME.
  ELSE.
    MESSAGE 'Job scheduled successfully' TYPE 'I'.
  ENDIF.

ENDFORM.                    "CREATEBATCHJOB

*---------------------------------------------------------------------*
*       FORM CHECKBATCHJOB                                            *
*---------------------------------------------------------------------*
FORM CHECKBATCHJOB USING JOBCOUNT TYPE TBTCJOB-JOBCOUNT
                         JOBNAME  TYPE TBTCJOB-JOBNAME.
  CONSTANTS: LC_RUNNING       LIKE TBTCO-STATUS VALUE 'R'
            ,LC_READY         LIKE TBTCO-STATUS VALUE 'Y'
            ,LC_SCHEDULED     LIKE TBTCO-STATUS VALUE 'P'
            ,LC_INTERCEPTED   TYPE BTCSTATUS VALUE LC_SCHEDULED
            ,LC_RELEASED      LIKE TBTCO-STATUS VALUE 'S'
            ,LC_ABORTED       LIKE TBTCO-STATUS VALUE 'A'
            ,LC_FINISHED      LIKE TBTCO-STATUS VALUE 'F'
            ,LC_PUT_ACTIVE    LIKE TBTCO-STATUS VALUE 'Z'
            ,LC_UNKNOWN_STATE LIKE TBTCO-STATUS VALUE 'X'.

  DATA: ERROR  TYPE STRING
       ,STATUS TYPE TBTCJOB-STATUS
       ,COMPLETE TYPE BOOLEAN
       ,IJOBLOG TYPE TABLE OF TBTC5
       ,PROGRESS_COUNT TYPE INTEGER "For progress bar display
       ,PERCENT_COMPLETE TYPE DECFLOAT34 VALUE 0
       ,PROGRESS_STRING TYPE STRING
       ,LOG_CHECK_LIMIT TYPE INTEGER VALUE 60.  "seconds
  FIELD-SYMBOLS: <ZJOBLOG> TYPE TBTC5.

* read the job log
  COMPLETE = ABAP_FALSE.
  PROGRESS_COUNT = 0.

  DO LOG_CHECK_LIMIT TIMES.  "<<<- this can be increased

*   check the job for completion / cancellation, etc.
    CALL FUNCTION 'BP_JOB_STATUS_GET'
      EXPORTING
        JOBCOUNT = JOBCOUNT
        JOBNAME  = JOBNAME
      IMPORTING
        STATUS   = STATUS
      EXCEPTIONS
        OTHERS   = 1.
    IF SY-SUBRC <> 0.
      CONCATENATE 'Error getting job status' JOBNAME INTO ERROR
        SEPARATED BY SPACE.
      MESSAGE ERROR TYPE 'I' DISPLAY LIKE 'E'.
      STOP.
    ENDIF.

*   Check if the job is completed
    IF STATUS = LC_FINISHED.
      COMPLETE = 'X'.
      EXIT.
    ELSEIF STATUS = LC_ABORTED.
      EXIT.
    ENDIF.

    WAIT UP TO 1 SECONDS.

*   Update Progess Meter if running in dialogue mode
    PROGRESS_COUNT   = PROGRESS_COUNT + 1.
    PERCENT_COMPLETE = ( PROGRESS_COUNT / LOG_CHECK_LIMIT ) * 100.
    PROGRESS_STRING = 'Attempting to retrieve log'.

    CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
      EXPORTING
        PERCENTAGE = PERCENT_COMPLETE
        TEXT       = PROGRESS_STRING.
  ENDDO.

  IF COMPLETE = SPACE.
*   The job may not have started yet (E.g. scheduled for 20:00 start)
    IF PROGRESS_COUNT EQ LOG_CHECK_LIMIT.
      CONCATENATE 'Scheduled job' JOBNAME 'has not started yet -'
        'please check job log' INTO ERROR SEPARATED BY SPACE.
    ELSE.
*     if the job aborted - something went wrong
      CONCATENATE 'Scheduled job' JOBNAME 'terminated with an error -'
        'please check job log' INTO ERROR SEPARATED BY SPACE.
    ENDIF.
    MESSAGE ERROR TYPE 'I' DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

* get the job log
  CALL FUNCTION 'BP_JOBLOG_READ'
    EXPORTING
      JOBCOUNT  = JOBCOUNT
      JOBNAME   = JOBNAME
    TABLES
      JOBLOGTBL = IJOBLOG
    EXCEPTIONS
      OTHERS    = 1.
  IF SY-SUBRC <> 0 OR IJOBLOG[] IS INITIAL.
    CONCATENATE 'Unable to read job log for job' JOBNAME INTO ERROR
      SEPARATED BY SPACE.
    MESSAGE ERROR TYPE 'I' DISPLAY LIKE 'E'.
    STOP.
  ENDIF.

* check for the success message
  LOOP AT IJOBLOG ASSIGNING <ZJOBLOG>
    WHERE MSGID = '00' AND MSGNO = '001' AND MSGTYPE = 'I'.
    IF <ZJOBLOG>-TEXT EQ 'Program ran successfully'
      OR <ZJOBLOG>-TEXT EQ 'Directory check complete'.
        MESSAGE <ZJOBLOG>-TEXT TYPE 'S'.
    ELSE.
      MESSAGE <ZJOBLOG>-TEXT TYPE 'I' DISPLAY LIKE 'E'.
    ENDIF.
  ENDLOOP.

ENDFORM.                    "CHECKBATCHJOB

*---------------------------------------------------------------------*
*       FORM PROCESSBATCHERROR                                        *
*---------------------------------------------------------------------*
FORM PROCESSBATCHERROR USING PMESSAGE.
  DATA: TYPE(2) TYPE C VALUE 'I'.

  IF PBTCTEST <> 'X'.
    TYPE = 'E'.
  ENDIF.

  MESSAGE PMESSAGE TYPE TYPE.
  STOP.
ENDFORM.                    "PROCESSBATCHERROR
