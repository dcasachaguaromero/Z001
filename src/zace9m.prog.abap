FORM GENPSTFORM.
  DATA: FLDCNT(3)  TYPE N
       ,WHRCNT(2) TYPE N
       ,LENG(4) TYPE N.

  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING '*       FORM EXPB3                               *'.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING 'FORM EXPB3.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '* FILE 1 BKPF'.
  PERFORM C1 USING ''.

  FLDCNT = 0.

  LOOP AT T_SELECT WHERE TABNAME = 'BKPF'.
    SELECT  SINGLE DATATYPE
                   FIELDNAME
                   LENG
                   POSITION
                   DECIMALS
       INTO (WDD03L-DATATYPE
            ,WDD03L-FIELDNAME
            ,WDD03L-LENG
            ,WDD03L-POSITION
            ,WDD03L-DECIMALS
            )
       FROM DD03L
      WHERE TABNAME  = T_SELECT-TABNAME
        AND FIELDNAME = T_SELECT-FLDNAME
        AND AS4LOCAL = 'A'.

    IF WDD03L-FIELDNAME+0(1) <> '.'.
      IF WDD03L-FIELDNAME = 'BUKRS'.
        FLDCNT = FLDCNT + 1.
        PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBKPF''' FLDCNT.
        PERFORM C1 USING '          ''BJAHR'''.
        PERFORM C1 USING '          9 ''Company Code @ Year'''.
        PERFORM C1 USING '          ''CoCd@Yr''.'.
      ELSEIF WDD03L-FIELDNAME <> 'GJAHR'.
        FLDCNT = FLDCNT + 1.
        PERFORM C2 USING '  PERFORM EXPB3V USING ''ACEBKPF''' FLDCNT.
        PERFORM D3 USING '          ''' WDD03L-FIELDNAME ''''.
        PERFORM C1 USING '          ''BKPF''.'.
      ENDIF.
    ENDIF.
  ENDLOOP.

  FLDCNT = FLDCNT + 1.
  PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBKPF''' FLDCNT.
  PERFORM C1 USING '          ''XDMBTR'''.
  PERFORM C1 USING '          33 ''Amount in Local Currency'''.
  PERFORM C1 USING '          ''Amount in LC''.'.
  FLDCNT = FLDCNT + 1.
  PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBKPF''' FLDCNT.
  PERFORM C1 USING '          ''XDIFF'''.
  PERFORM C1 USING '          33 ''Amount in doc currency'''.
  PERFORM C1 USING '          ''Amount in doc curr''.'.
  FLDCNT = FLDCNT + 1.
  PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBKPF''' FLDCNT.
  PERFORM C1 USING '          ''XDIFF'''.
  PERFORM C1 USING '          33 ''Difference in doc currency'''.
  PERFORM C1 USING '          ''Diff in doc curr''.'.
  FLDCNT = FLDCNT + 1.
  PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBKPF''' FLDCNT.
  PERFORM C1 USING '          ''XKOART'''.
  PERFORM C1 USING '          11 ''Summary of Account Type'''.
  PERFORM C1 USING '          ''Sum Acc Type''.'.
  FLDCNT = FLDCNT + 1.
  PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBKPF''' FLDCNT.
  PERFORM C1 USING '          ''XBUZEI'''.
  PERFORM C1 USING '          3 ''Number of Line Items'''.
  PERFORM C1 USING '          ''Num Items''.'.
  PERFORM C1 USING ''.

  FLDCNT = 0.

  PERFORM C1 USING ''.
  PERFORM C1 USING '* FILE 2 BSEG'.
  PERFORM C1 USING ''.

  LOOP AT T_SELECT WHERE TABNAME = 'BSEG'.
    SELECT  SINGLE DATATYPE
                   FIELDNAME
                   LENG
                   POSITION
                   DECIMALS
       INTO (WDD03L-DATATYPE
            ,WDD03L-FIELDNAME
            ,WDD03L-LENG
            ,WDD03L-POSITION
            ,WDD03L-DECIMALS
            )
       FROM DD03L
      WHERE TABNAME  = T_SELECT-TABNAME
        AND FIELDNAME = T_SELECT-FLDNAME
        AND AS4LOCAL = 'A'.

    IF WDD03L-FIELDNAME+0(1) <> '.'.
      IF WDD03L-FIELDNAME = 'BUKRS'.
        FLDCNT = FLDCNT + 1.
        PERFORM C2 USING '  PERFORM EXPB3W USING ''ACEBSEG'' ' FLDCNT.
        PERFORM C1 USING '          ''BJAHR'''.
        PERFORM C1 USING '          9 ''Company Code @ Year'''.
        PERFORM C1 USING '          ''CoCd@Yr''.'.
      ELSEIF WDD03L-FIELDNAME <> 'GJAHR'.
        FLDCNT = FLDCNT + 1.
        PERFORM C2 USING '  PERFORM EXPB3V USING ''ACEBSEG''' FLDCNT.
        PERFORM D3 USING '          ''' WDD03L-FIELDNAME ''''.
        PERFORM C1 USING '          ''BSEG''.'.
      ENDIF.
    ENDIF.
  ENDLOOP.

  PERFORM C1 USING ''.
  PERFORM C1 USING '* FILE 3 ACEBELNR'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '  PERFORM EXPB3W USING ''ACEBELNR'' 1 ''CVAL'''.
  PERFORM C1 USING '          8 ''Code Value'' ''Code Value''.'.
  PERFORM C1 USING '  PERFORM EXPB3W USING ''ACEBELNR'' 2 ''CID'''.
  PERFORM C1 USING '          10 ''Code ID'' ''Code ID''.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '* FILE 4 ACEPOSCODES'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '  PERFORM EXPB3W USING ''ACEPOSCODES'' 1 ''CTYPE'''.
  PERFORM C1 USING '          6 ''Code Type'' ''Code Type''.'.
  PERFORM C1 USING '  PERFORM EXPB3W USING ''ACEPOSCODES'' 2 ''CVAL'''.
  PERFORM C1 USING '          8 ''Code Value'' ''Code Value''.'.
  PERFORM C1 USING '  PERFORM EXPB3W USING ''ACEPOSCODES'' 3 ''CID'''.
  PERFORM C1 USING '          30 ''Code ID'' ''Code ID''.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING 'ENDFORM.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING '*       FORM EXPB45                              *'.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING 'FORM EXPB45.'.
  PERFORM C1 USING '  PERFORM EXPB4RECY USING TNAME TTEXT SREC.'.
  PERFORM C1 USING '  PERFORM EXPB4RECY USING TNAM2 TTEX2 SRE2.'.
  PERFORM C1 USING '  PERFORM EXPB4RECY USING TNAM3 TTEX3 SRE3.'.
  PERFORM C1 USING '  PERFORM EXPB4RECY USING TNAM4 TTEX4 SRE4.'.
  PERFORM C1 USING 'ENDFORM.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING '*       FORM PROC                                *'.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING 'FORM PROC.'.
  PERFORM C1 USING '  TNAME = ''ACEBKPF''.'.
  PERFORM C1 USING '  TTEXT = ''Int. table Posting Header''.'.
  PERFORM C1 USING '  TNAM2 = ''ACEBSEG''.'.
  PERFORM C1 USING '  TTEX2 = ''Int. table Posting Detail''.'.
  PERFORM C1 USING '  TNAM3 = ''ACEBELNR''.'.
  PERFORM C1 USING '  TTEX3 = ''Int. table Posting Document Numbers''.'.
  PERFORM C1 USING '  TNAM4 = ''ACEPOSCODES''.'.
  PERFORM C1 USING '  TTEX4 = ''Int. table Posting Codes''.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '  PERFORM GETNEXTFILENO CHANGING FN2.'.
  PERFORM C1 USING '  PERFORM FILEOPEN USING FTYPE FN2 ''OUTPUT''.'.
  PERFORM C1 USING '  PERFORM FILECLOSE USING FTYPE FN2.'.
  PERFORM C1 USING '  PERFORM GETNEXTFILENO CHANGING FN3.'.
  PERFORM C1 USING '  PERFORM FILEOPEN USING FTYPE FN3 ''OUTPUT''.'.
  PERFORM C1 USING '  PERFORM FILECLOSE USING FTYPE FN3.'.
  PERFORM C1 USING ''.

* Import FROM  MEMORY
* ===================
  PERFORM C1 USING '  IMPORT SEL01 SEL02 SEL03 SEL04 SEL05'.
  PERFORM C1 USING '         SEL06 SEL07 SEL08 SEL09 SEL10'.
  PERFORM C1 USING '         SEL11 SEL12 SEL13 SEL14 SEL15'.
  PERFORM D3 USING '    FROM MEMORY ID ''' MEMID '''.'.
  PERFORM C1 USING ''.

* Stepwise SELECT
* ===============
  PERFORM C1 USING '  SELECT BUKRS'.
  PERFORM C1 USING '    INTO table'.
  PERFORM C1 USING '         ibukrs'.
  PERFORM C1 USING '    FROM T001.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '  LOOP AT ibukrs ASSIGNING <zbukrs>.'.
  PERFORM C1 USING '    PERFORM STARTDOWNLOAD.'.
  PERFORM C1 USING '    PERFORM FILEOPEN USING FTYPE FN2'.
  PERFORM C1 USING '                                  ''APPENDING''.'.
  PERFORM C1 USING '    PERFORM FILEOPEN USING FTYPE FN3'.
  PERFORM C1 USING '                                  ''APPENDING''.'.
  PERFORM C1 USING ''.

* GENERATE: SELECT
* ================
  PERFORM C1 USING '    SELECT'.

  LOOP AT T_SELECT WHERE TABNAME = 'BKPF'.
    CLEAR CONCAT.
    WRITE T_SELECT-FLDNAME TO CONCAT+11.
    PERFORM C1 USING CONCAT.
  ENDLOOP.

  PERFORM C1 USING '      FROM BKPF'.
  PERFORM C1 USING '      INTO CORRESPONDING FIELDS OF ITAB'.
  PERFORM C1 USING '     WHERE BUKRS = <zbukrs>-BUKRS'.

  LOOP AT T_WHERE WHERE TABNAME = 'BKPF'.
    WHRCNT = WHRCNT + 1.

    CONCATENATE 'SEL' WHRCNT
                INTO TXT2STR.
    CONCATENATE '       AND' T_WHERE-FLDNAME 'IN' TXT2STR
                INTO CONCAT
                SEPARATED BY SPACE.
    PERFORM C1 USING CONCAT.
  ENDLOOP.

  PERFORM C1 USING '       .'.

