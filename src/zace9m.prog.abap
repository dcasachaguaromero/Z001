                                ' ''SYSLOG-CATCH_ERRNO'' ''I'''.
  PERFORM C1 USING '                                     ''C'' TXTSTR.'.
  PERFORM C1 USING '            ENDIF.'.
  PERFORM C1 USING '            IF CATCH_T100 = ''X''.'.
  PERFORM C1 USING '              MOVE <WORDS_PTR> TO TXTSTR.'.
  PERFORM D2 USING '              PERFORM EXPB1REC USING'
                                ' ''SYSLOG-CATCH_T100'' ''I'''.
  PERFORM C1 USING '                                     ''C'' TXTSTR.'.
  PERFORM C1 USING '            ENDIF.'.
  PERFORM C1 USING '          ENDIF.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '        ELSE. " ident not in range ''A'',..,''P'''.
  PERFORM C1 USING '          IF ''abcdefghij'' CA <TMP_PTR>.'.
  PERFORM D2 USING '*           " &a, &b,.. identify one of the'
