*---------------------------------------------------------------------*
*       FORM INITBFILES                                               *
*---------------------------------------------------------------------*
FORM INITBFILES USING FNO.
  PERFORM FILEOPEN USING 'B' FNO 'OUTPUT'.
  PERFORM FILECLOSE USING 'B' FNO.
ENDFORM.                    "INITBFILES

*---------------------------------------------------------------------*
*       FORM EXPB1REC                                                 *
*---------------------------------------------------------------------*
FORM EXPB1REC USING INFONAME INFOTYPE INFOVALTYPE INFOVALUE.
  DATA: BEGIN OF WB1
       ,INFODATETIME(14) TYPE C
       ,INFONAME(50) TYPE C
       ,INFOTYPE(1) TYPE C
       ,INFOVALTYPE(1) TYPE C
       ,INFOCVALUE(2000) TYPE C
       ,INFONVALUE(50) TYPE C
       ,END OF WB1.

  CLEAR WB1.
  CONCATENATE SY-DATUM
              SY-UZEIT
         INTO WB1-INFODATETIME.
  WB1-INFONAME = INFONAME.
  WB1-INFOTYPE = INFOTYPE.
  WB1-INFOVALTYPE = INFOVALTYPE.
  IF INFOVALTYPE = 'C'.
    WB1-INFOCVALUE = INFOVALUE.
  ELSE.
    WB1-INFONVALUE = INFOVALUE.
    SHIFT WB1-INFONVALUE LEFT DELETING LEADING '0'.
    CONDENSE WB1-INFONVALUE NO-GAPS.
  ENDIF.

  PERFORM FILEOPEN USING 'B' 1 'APPENDING'.

  CONCATENATE WB1-INFODATETIME
              WB1-INFONAME
              WB1-INFOTYPE
              WB1-INFOVALTYPE
              WB1-INFOCVALUE
              WB1-INFONVALUE
              INTO TREC
              SEPARATED BY TRANSHS.
  PERFORM FILETRANS USING 'B' 1.

  IF INFOTYPE = 'T' OR INFOTYPE = 'P'.
    CONCATENATE INFONAME ':' INTO TXTSTR.
    CONCATENATE TXTSTR INFOVALUE INTO CONCAT
                       SEPARATED BY SPACE.
    MESSAGE ID 'AD' TYPE 'S' NUMBER 10
                         WITH CONCAT.
  ELSEIF INFOTYPE = 'E'.
    CONCATENATE INFONAME ':' INTO TXTSTR.
    CONCATENATE TXTSTR INFOVALUE INTO CONCAT
                       SEPARATED BY SPACE.
    MESSAGE ID 'AD' TYPE 'E' NUMBER 10
                         WITH CONCAT.
  ENDIF.

  PERFORM FILECLOSE USING 'B' 1.
ENDFORM.                    "EXPB1REC

*---------------------------------------------------------------------*
*       FORM EXPB6                                                    *
*---------------------------------------------------------------------*
FORM EXPB6.
  PERFORM FILEOPEN USING 'B' 6 'OUTPUT'.

  LOOP AT CODE ASSIGNING <ZCODE>.
    TREC = <ZCODE>.
    PERFORM FILETRANS USING 'B' 6.
  ENDLOOP.

  PERFORM FILECLOSE USING 'B' 6.
ENDFORM.                    "EXPB6

*---------------------------------------------------------------------*
*       FORM EXPB7                                                    *
*---------------------------------------------------------------------*
FORM EXPB7.
  DATA: SUBNUM(5) TYPE C.

  PERFORM FILEOPEN USING 'B' 7 'OUTPUT'.

  READ REPORT SY-REPID INTO CODE.
  IF SY-SUBRC <> 0.
    SUBNUM = SY-SUBRC.
    CONCATENATE 'Error getting'
                SY-REPID
                'source code:'
                'E:' SUBNUM
                INTO CONCAT
                SEPARATED BY SPACE.
    PERFORM EXPB1REC USING 'EXPB7' 'I' 'C' CONCAT.

    PERFORM FILECLOSE USING 'B' 7.

    EXIT.
  ENDIF.

  LOOP AT CODE ASSIGNING <ZCODE>.
    TREC = <ZCODE>.
    PERFORM FILETRANS USING 'B' 7.
  ENDLOOP.

  PERFORM FILECLOSE USING 'B' 7.
ENDFORM.                    "EXPB7

*---------------------------------------------------------------------*
*      Form  SUBMITTEMP                                               *
*---------------------------------------------------------------------*
FORM SUBMITTEMP.
  PERFORM EXECCOMMIT USING 'SUBMIT-A'.

  SUBMIT (SUBREPID) WITH SP = 'S'
                    WITH DWNLFLAG =  WEXP-DOWNLOAD
                    WITH GEN      =  WEXP-GEN
                    WITH FLDLST   =  WEXP-FLDLST
                    AND RETURN.

  PERFORM EXECCOMMIT USING 'SUBMIT-B'.
ENDFORM.                    "SUBMITTEMP

*---------------------------------------------------------------------*
*      Form  DYNAPPENDSELECT                                          *
*---------------------------------------------------------------------*
FORM DYNAPPENDSELECT USING TABNAME FLDNAME.
  SELECT  SINGLE DATATYPE
                 FIELDNAME
                 LENG
                 POSITION
           INTO (WDD03L-DATATYPE
                ,WDD03L-FIELDNAME
                ,WDD03L-LENG
                ,WDD03L-POSITION
                )
            FROM DD03L
           WHERE TABNAME   = TABNAME
             AND FIELDNAME = FLDNAME
             AND AS4LOCAL  = 'A'.

  IF SY-SUBRC = 0.
    T_SELECT-TABNAME = TABNAME.
    T_SELECT-FLDNAME = FLDNAME.
    APPEND T_SELECT.
  ENDIF.
ENDFORM.                    "DYNAPPENDSELECT

*---------------------------------------------------------------------*
*      Form  DYNAPPENDWHERE                                          *
*---------------------------------------------------------------------*
FORM DYNAPPENDWHERE USING TABNAME FLDNAME.
  T_WHERE-TABNAME = TABNAME.
  T_WHERE-FLDNAME = FLDNAME.
  APPEND T_WHERE.
ENDFORM.                    "DYNAPPENDWHERE

*---------------------------------------------------------------------*
*       FORM EXECCOMMIT                                               *
*---------------------------------------------------------------------*
FORM EXECCOMMIT USING SUBCOMMIT.
  DATA: SUBNUM(5) TYPE C.

  COMMIT WORK AND WAIT.

  IF SY-SUBRC <> 0.
    SUBNUM = SY-SUBRC.
    CONCATENATE 'Commit was not possible:'
                'Return' SUBNUM
                'in location' WEXP-LOCATION
                'at location' SUBCOMMIT
                INTO CONCAT
                SEPARATED BY SPACE.
      PERFORM EXPB1REC USING 'COMMIT' 'E' 'C' CONCAT.
  ENDIF.
ENDFORM.                    "EXECCOMMIT

*---------------------------------------------------------------------*
*       FORM FILEOPEN                                                 *
*---------------------------------------------------------------------*
FORM FILEOPEN USING FTYPE FNO OPENTYPE.
  PERFORM GETFILENAME USING FTYPE FNO CHANGING FNAME.

  IF OPENTYPE = 'OUTPUT'.
    OPEN DATASET FNAME FOR OUTPUT
                 IN TEXT MODE
                 ENCODING UTF-8
                 REPLACEMENT CHARACTER REPLQ
                 IGNORING CONVERSION ERRORS
                 MESSAGE TXT2STR.
  ELSE.
    OPEN DATASET FNAME FOR APPENDING
                 IN TEXT MODE
                 ENCODING UTF-8
                 REPLACEMENT CHARACTER REPLQ
                 IGNORING CONVERSION ERRORS
                 MESSAGE TXT2STR.
  ENDIF.

  IF SY-SUBRC <> 0.
    TXTSTR = SY-SUBRC.
    CONCATENATE 'File-Open-Error:' FNAME TXTSTR TXT2STR
                INTO CONCAT
                SEPARATED BY SPACE.
    MESSAGE ID 'AD' TYPE 'S' NUMBER 10 WITH CONCAT.
    EXIT.
  ENDIF.
ENDFORM.                    "FILEOPEN

*---------------------------------------------------------------------*
*       FORM FILECLOSE                                                *
*---------------------------------------------------------------------*
FORM FILECLOSE USING FTYPE FNO.
  PERFORM GETFILENAME USING FTYPE FNO CHANGING FNAME.

  CLOSE DATASET FNAME.

  IF SY-SUBRC <> 0.
    TXTSTR = SY-SUBRC.
    CONCATENATE 'File-Close-Error:' FNAME TXTSTR
                INTO CONCAT
                SEPARATED BY SPACE.
    MESSAGE ID 'AD' TYPE 'S' NUMBER 10 WITH CONCAT.
    EXIT.
  ENDIF.
ENDFORM.                    "FILECLOSE

*---------------------------------------------------------------------*
*       FORM FILETRANS                                                *
*---------------------------------------------------------------------*
FORM FILETRANS USING FTYPE FNO.
  PERFORM GETFILENAME USING FTYPE FNO CHANGING FNAME.

* If not current Temp file or Master file respectively
  IF FNO <> 6 AND FNO <> 7.
    REPLACE ALL OCCURRENCES OF TRANSH1 IN TREC WITH SPACE.
    REPLACE ALL OCCURRENCES OF TRANSH2 IN TREC WITH SPACE.
    REPLACE ALL OCCURRENCES OF TRANSQ1 IN TREC WITH REPLQ.
    REPLACE ALL OCCURRENCES OF TRANSQ2 IN TREC WITH REPLQ.
  ENDIF.

  TRANSFER TREC TO FNAME.
ENDFORM.                    "FILETRANS

*---------------------------------------------------------------------*
*       FORM GETFILENAME                                              *
*---------------------------------------------------------------------*
FORM GETFILENAME USING FTYPE FNO CHANGING FILENAME.
  DATA: FID(5) TYPE N.

  FID = FNO.
  CONCATENATE PPATH FTYPE FID FEXT
              INTO FILENAME.
ENDFORM.                    "GETFILENAME

*---------------------------------------------------------------------*
*       FORM REPLQFIELD                                            *
*---------------------------------------------------------------------*
FORM REPLQFIELD USING FLD.
  REPLACE ALL OCCURRENCES OF TRANSHS IN FLD WITH SPACE.
ENDFORM.                    "REPLQFIELD

*---------------------------------------------------------------------*
*      Form  CHECKTABEXISTS                                           *
*---------------------------------------------------------------------*
FORM CHECKTABEXISTS USING TABNAME CHANGING EXFLAG.
  DATA: NUMREC TYPE I.

  SELECT   COUNT( * )
      INTO NUMREC
      FROM DD02L
     WHERE TABNAME = TABNAME
       AND AS4VERS = 'A'
       AND TABCLASS <> 'INTTAB'.

  IF SY-SUBRC NE 0.
    CONCATENATE 'Information: ' TABNAME ' table does not exist.'
                INTO CONCAT.
    PERFORM EXPB1REC USING 'CHKTABLE' 'I' 'C' CONCAT.
    EXFLAG = SPACE.
  ELSE.
    EXFLAG = 'X'.
  ENDIF.
ENDFORM.                    "CHECKTABEXISTS

