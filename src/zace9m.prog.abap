*---------------------------------------------------------------------*
*      Form  EXPTABLOG                                                *
*---------------------------------------------------------------------*
FORM EXPTABLOG.
  DATA: CHKDONE(1) TYPE C.

  WEXP-LOCATION = 'ACETABLOG'.
  WEXP-FTYPE = 'M'.
  WEXP-TABNAME = 'ACETABLOG'.
  WEXP-TABTEXT = 'Table Log'.
  WEXP-SCHEMA = 'NA'.
  WEXP-QUERIES = 'N'.
  WEXP-GEN = ''.
  WEXP-FLDLST = ''.

  IF PLOGTAB = 'X'.
    WEXP-DOWNLOAD = 'Y'.
  ELSE.
    WEXP-DOWNLOAD = 'N'.
  ENDIF.

  CHKDONE = ' '.

  IF PLOGALL = 'X'.
    PERFORM EXPTABLOGEXEC USING 'T000' CHKDONE ''.
  ELSE.
*   T000 needs always to be downloaded client independent.
    PERFORM EXPTABLOGEXEC USING 'T000' CHKDONE ''.
  ENDIF.

ENDFORM.                    "EXPTABLOG

*---------------------------------------------------------------------*
*      Form  EXPTABLOGEXEC                                            *
*---------------------------------------------------------------------*
FORM EXPTABLOGEXEC USING CURTABNAME CHKDONE MANDTFLD.
  DATA: NUMREC TYPE I,
        COUNTFIELD TYPE I,
        MAXFIELD(5) TYPE N.

  SELECT        COUNT( * )
           INTO NUMREC
           FROM DD02L
          WHERE TABNAME = CURTABNAME
            AND AS4VERS = 'A'
            AND TABCLASS <> 'INTTAB'.

  IF SY-SUBRC = 4.
    CONCATENATE 'Information: ' CURTABNAME ' table do not exist.'
                INTO CONCAT.
    PERFORM EXPB1REC USING 'TABLOGCHKTAB' 'I' 'C' CONCAT.
    EXIT.
  ENDIF.

  SELECT        COUNT( * )
           INTO COUNTFIELD
           FROM DD03L
          WHERE TABNAME = CURTABNAME
            AND AS4LOCAL = 'A'.

  IF SY-SUBRC = 4.
    CONCATENATE 'Information: ' CURTABNAME ' table do not exist.'
                INTO CONCAT.
    PERFORM EXPB1REC USING 'TABLOGCHKFLD' 'I' 'C' CONCAT.
    EXIT.
  ENDIF.

  MAXFIELD = COUNTFIELD.

  PERFORM GENCONSTSTART.
  PERFORM GENTABLOGSHARED USING CURTABNAME.
  PERFORM GENCONSTFORM.
  PERFORM GENTABLOGFORM USING CHKDONE CURTABNAME MAXFIELD MANDTFLD.
  PERFORM GENABAP.

  PERFORM SUBMITTEMP.
ENDFORM.                    "EXPTABLOGEXEC

