  PERFORM C1 USING '      TOU3-CVAL = NBELNR.'.
  PERFORM C1 USING '      SHIFT TOU3-CVAL'.
  PERFORM C1 USING '            LEFT DELETING LEADING ''0''.'.
  PERFORM C1 USING '      TOU3-CID = TOUT-BELNR.'.
  PERFORM C1 USING '      CONCATENATE TOU3-CVAL TOU3-CID'.
  PERFORM C1 USING '                  INTO TREC'.
  PERFORM C1 USING '                  SEPARATED BY TRANSHS.'.
  PERFORM C1 USING '      PERFORM FILETRANSFER'.
  PERFORM C1 USING '              USING    FTYPE'.
  PERFORM C1 USING '              CHANGING FN3 FBYT3 FRE3 SRE3.'.
  PERFORM C1 USING ''.

