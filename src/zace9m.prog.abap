  PERFORM C1 USING '          CASE <TMP_PTR>.'.
  PERFORM C1 USING '            WHEN ''E''.'.
  PERFORM C1 USING '              CATCH_ERRNO = ''X''.'.
  PERFORM C1 USING '              ASSIGN <TMP_PTR>+1(1) TO <TMP_PTR>.'.
  PERFORM C1 USING '              ADD 2 TO L_SKIP_PARAM.'.
  PERFORM C1 USING '            WHEN ''M''.'.
  PERFORM C1 USING '              CATCH_T100 = ''X''.'.
  PERFORM C1 USING '              ASSIGN <TMP_PTR>+1(1) TO <TMP_PTR>.'.
  PERFORM C1 USING '              ADD 2 TO L_SKIP_PARAM.'.
  PERFORM C1 USING '            WHEN OTHERS.'.
  PERFORM D2 USING '*             " A ''&>'' followed by something'
                                  ' strange tries to ignore'.
  PERFORM C1 USING '*             " the ''>''.'.
  PERFORM C1 USING '              MOVE ''&'' TO <DEST_PTR>.'.
