                                  ' <DEST_PTR>.'.
  PERFORM C1 USING '              DEST_LEN = DEST_LEN - 1.'.
  PERFORM C1 USING '              ADD 1 TO L_SKIP_PARAM.'.
  PERFORM C1 USING '          ENDCASE.'.
  PERFORM C1 USING '        ENDIF. " &>...'.
  PERFORM C1 USING ''.
