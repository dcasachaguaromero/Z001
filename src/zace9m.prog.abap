*---------------------------------------------------------------------*
*       FORM SELDROPDOWNS                                             *
*---------------------------------------------------------------------*
FORM SELDROPDOWNS.
  TYPE-POOLS: VRM.
  DATA: WDROPDOWN TYPE VRM_VALUE
       ,IDROPDOWN TYPE VRM_VALUES
       ,SERVER_PARAMETER(12) VALUE 'rdisp/myname'
       ,ISERVER TYPE TABLE OF SAPWLSERV
       ,NUMREC TYPE I.
  FIELD-SYMBOLS <ZSERVER> LIKE LINE OF ISERVER.

* Application Servers

  SELECT *
    INTO TABLE ISERVER
    FROM SAPWLSERV.
  DESCRIBE TABLE ISERVER LINES NUMREC.

  REFRESH IDROPDOWN.
  LOOP AT ISERVER ASSIGNING <ZSERVER>.
    WDROPDOWN-KEY = <ZSERVER>-NAME.
    WDROPDOWN-TEXT = <ZSERVER>-NAME.
    APPEND WDROPDOWN TO IDROPDOWN.
  ENDLOOP.

  CALL FUNCTION 'VRM_SET_VALUES'
    EXPORTING
      ID     = 'PSERVER'
      VALUES = IDROPDOWN.

* Determine the current application server
  CALL 'C_SAPGPARAM'
    ID 'NAME'  FIELD SERVER_PARAMETER
    ID 'VALUE' FIELD SERVER.

  IF PSERVER IS INITIAL AND NUMREC = 1.
    PSERVER = SERVER.
  ENDIF.

* Batch Job Option - Class

  CLEAR IDROPDOWN.
  REFRESH IDROPDOWN.
  WDROPDOWN-KEY = 'A'.
  WDROPDOWN-TEXT = 'A'.
  APPEND WDROPDOWN TO IDROPDOWN.

  WDROPDOWN-KEY = 'B'.
  WDROPDOWN-TEXT = 'B'.
  APPEND WDROPDOWN TO IDROPDOWN.

  WDROPDOWN-KEY = 'C'.
  WDROPDOWN-TEXT = 'C'.
  APPEND WDROPDOWN TO IDROPDOWN.

  CALL FUNCTION 'VRM_SET_VALUES'
    EXPORTING
      ID     = 'PBTCCLAS'
      VALUES = IDROPDOWN.
ENDFORM.                    "SELDROPDOWNS

*---------------------------------------------------------------------*
*       FORM PROCESSSYSINFO                                           *
*---------------------------------------------------------------------*
FORM PROCESSSYSINFO.
  DATA: INSTNO(10) TYPE C.

  PERFORM EXPB1REC USING 'EXPDATE' 'S' 'C' SY-DATUM.
  PERFORM EXPB1REC USING 'SYSID' 'S' 'C' SY-SYSID.
  PERFORM EXPB1REC USING 'OS' 'S' 'C' SY-OPSYS.
  PERFORM EXPB1REC USING 'DB'  'S' 'C' SY-DBSYS.
  PERFORM EXPB1REC USING 'HOST' 'S' 'C' SY-HOST.
  PERFORM EXPB1REC USING 'SAPREL' 'S' 'C' SY-SAPRL.
  PERFORM EXPB1REC USING 'MANDT' 'S' 'C' SY-MANDT.
  CALL FUNCTION 'SLIC_GET_LICENCE_NUMBER'
     IMPORTING
          LICENSE_NUMBER = INSTNO.
  PERFORM EXPB1REC USING 'INSTNO' 'S' 'C' INSTNO.
  PERFORM EXPB1REC USING 'ACEM' 'S' 'C' SY-REPID.
  PERFORM EXPB1REC USING 'ACET' 'S' 'C' SUBREPID.
  PERFORM EXPB1REC USING 'ACEREL' 'S' 'C' REPREL.
  PERFORM EXPB1REC USING 'ACEMINVERSION' 'S' 'C' ACEMIN.
  PERFORM EXPB1REC USING 'USER' 'S' 'C' SY-UNAME.
  IF CL_ABAP_CHAR_UTILITIES=>CHARSIZE = 1.
    PERFORM EXPB1REC USING 'UCS' 'S' 'C' 'No'.
  ELSE.
    PERFORM EXPB1REC USING 'UCS' 'S' 'C' 'Yes'.
  ENDIF.
ENDFORM.                    "PROCESSSYSINFO

