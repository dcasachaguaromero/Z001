*---------------------------------------------------------------------*
*     FORM ADDB45                                                     *
*---------------------------------------------------------------------*
FORM ADDB45 USING TABNAME.
  DATA: NUMREC TYPE I
       ,LANGFIELD LIKE DD03L-FIELDNAME
       ,TABNAMETEXT LIKE DD03L-TABNAME
       ,LANGFIELDTEXT LIKE DD03L-FIELDNAME
       ,DUMMYORDER LIKE DD08VV-AS4VERS
       ,POSFLD TYPE I
       ,POSFLD2 TYPE I
       ,TABTEXT(60) TYPE C
       ,SELFLAG(40) TYPE C
       ,EXFLAG(1) TYPE C.

  IF TABNAME = 'REPOSRC'.
    IF TB4-LIMIT = ADDLIMIT AND STDLIMIT <> ADDLIMIT.
*     ok
    ELSE.
      TB4-FLDLIST = ''.
      EXIT.
    ENDIF.
  ELSEIF TABNAME = 'USR02'.

*   Check if PASSCODE field exists in current version
    SELECT        COUNT( * )
             INTO NUMREC
             FROM DD03L
            WHERE TABNAME    = 'USR02'
              AND FIELDNAME = 'PASSCODE'
              AND AS4LOCAL   = 'A'.

    IF NUMREC = 0.
*     If PASSCODE field does not exist
      CONCATENATE
      'MANDT#BNAME#GLTGV#GLTGB#USTYP#CLASS#LOCNT#UFLAG#'
      'ACCNT#ANAME#ERDAT#TRDAT#LTIME#BCDA1#CODV1#BCDA2#'
      'CODV2#BCDA3#CODV3#BCDA4#CODV4#BCDA5#CODV5#VERSN#'
      'TZONE#ZBVMASTER'
      INTO TB4-FLDLIST.

    ELSE.
*     If PASSCODE field exists
      CONCATENATE
      'MANDT#BNAME#GLTGV#GLTGB#USTYP#CLASS#LOCNT#UFLAG#'
      'ACCNT#ANAME#ERDAT#TRDAT#LTIME#BCDA1#CODV1#BCDA2#'
      'CODV2#BCDA3#CODV3#BCDA4#CODV4#BCDA5#CODV5#VERSN#'
      'TZONE#ZBVMASTER#PWDCHGDATE#PWDSTATE#RESERVED#'
      'PWDHISTORY#PWDLGNDATE#PWDSETDATE#PWDINITIAL#PWDLOCKDATE'
      INTO TB4-FLDLIST.

    ENDIF.

  ELSEIF TABNAME = 'USH02'.
    CONCATENATE
    'MANDT#BNAME#MODDA#MODTI#MODBE#TCODE#REPID#GLTGV#'
    'GLTGB#USTYP#CLASS#UFLAG#ACCNT#PWDINITIAL'
    INTO TB4-FLDLIST.
  ENDIF.

* Check if table has any fields of type rawstring/string
  SELECT        COUNT( * )
           INTO NUMREC
           FROM DD03L
          WHERE TABNAME    = TABNAME
            AND ( DATATYPE = 'RAWSTRING'
              OR  DATATYPE = 'RSTR'
              OR  DATATYPE = 'STRG' )
            AND AS4LOCAL   = 'A'.

  IF NUMREC > 0.
    EXIT.
  ENDIF.

  TRANSLATE TB4-STAB TO UPPER CASE.
  TRANSLATE TB4-SDV TO UPPER CASE.

  DATA: FLDTAB TYPE TABLE OF STRING,
        FLDVAL(30) TYPE C,
        FLDSEARCH(32) TYPE C.

  READ TABLE IB4 WITH KEY TABNAME = TABNAME
                 ASSIGNING <ZB4>.

* ENTRY ALREADY EXISTS

  IF SY-SUBRC = 0.

    " FTYPE

    IF TB4-FTYPE = 'M' OR <ZB4>-FTYPE = 'M'.     <ZB4>-FTYPE = 'M'.
    ELSEIF TB4-FTYPE = 'O' OR <ZB4>-FTYPE = 'O'. <ZB4>-FTYPE = 'O'.
    ENDIF.

    " FLAGS

    IF <ZB4>-MANDATORY = ''.    <ZB4>-MANDATORY = TB4-MANDATORY. ENDIF.
    IF <ZB4>-CLIENT = ''.       <ZB4>-CLIENT    = TB4-CLIENT.    ENDIF.
    IF <ZB4>-FFSD = ''.         <ZB4>-FFSD      = TB4-FFSD.      ENDIF.
    IF <ZB4>-FAGF = ''.         <ZB4>-FAGF      = TB4-FAGF.      ENDIF.

    SELFLAG = 'A                   '.
    POSFLD = -1.
    DO 19 TIMES.
      POSFLD2 = POSFLD + 1.
      IF POSFLD > -1.
        IF TB4-STAB+POSFLD(1) <> ' '.
          SELFLAG+POSFLD2(1) = 'X'.
        ELSEIF <ZB4>-STAB+POSFLD2(1) <> ' '.
          SELFLAG+POSFLD2(1) = 'X'.
        ENDIF.
      ENDIF.
      POSFLD = POSFLD + 1.
    ENDDO.
    <ZB4>-STAB = SELFLAG.

    SELFLAG = 'A                   '.
    POSFLD = -1.
    DO 19 TIMES.
      POSFLD2 = POSFLD + 1.
      IF POSFLD > -1.
        IF TB4-SDV+POSFLD(1) <> ' '.
          SELFLAG+POSFLD2(1) = 'X'.
        ELSEIF <ZB4>-SDV+POSFLD2(1) <> ' '.
          SELFLAG+POSFLD2(1) = 'X'.
        ENDIF.
      ENDIF.
      POSFLD = POSFLD + 1.
    ENDDO.
    <ZB4>-SDV = SELFLAG.

    " LIMIT

    IF <ZB4>-LIMIT < TB4-LIMIT.
      <ZB4>-LIMIT = TB4-LIMIT.
    ENDIF.

    " GENERATE

    IF TB4-GENERATE = '' OR <ZB4>-GENERATE = ''.
      <ZB4>-GENERATE = ''.
    ENDIF.

    " FIELD LIST

    REFRESH FLDTAB.

    SPLIT <ZB4>-FLDLIST AT '#' INTO TABLE FLDTAB.

    LOOP AT FLDTAB INTO FLDVAL.
      CONCATENATE '#' FLDVAL '#'
                  INTO FLDSEARCH.

      SEARCH <ZB4>-FLDLIST FOR FLDSEARCH.

      IF SY-SUBRC = 0.
        CONCATENATE <ZB4>-FLDLIST FLDVAL '#'
                    INTO <ZB4>-FLDLIST.
      ENDIF.
    ENDLOOP.

    " QUERIES

    IF <ZB4>-QUERIES <> '' OR TB4-QUERIES <> ''.
      <ZB4>-QUERIES = 'Y'.
    ENDIF.

    MODIFY IB4 FROM <ZB4> INDEX SY-TABIX.

    TB4-FLDLIST = ''.
    EXIT.
  ENDIF.

* ENTRY DOES NOT YET EXIST

* Check if table exists
  PERFORM CHECKTABEXISTS USING TABNAME CHANGING EXFLAG.

  IF EXFLAG <> 'X'.
    CLEAR WB4.
    WB4-FTYPE = TB4-FTYPE.
    WB4-TABNAME = TABNAME.
    WB4-TABTEXT = ''.
    WB4-LANGFIELD = ''.
    WB4-TABNAMETEXT = ''.
    WB4-LANGFIELDTEXT = ''.
    WB4-SCHEMA = 'NA'.
    WB4-QUERIES = 'N'.
    WB4-LIMIT = TB4-LIMIT.
    WB4-GENERATE = TB4-GENERATE.
    WB4-MANDATORY = TB4-MANDATORY.
    WB4-CLIENT = TB4-CLIENT.
    WB4-FFSD = TB4-FFSD.
    WB4-FAGF = TB4-FAGF.
    WB4-STAB = 'A'.
    WB4-STAB+1 = TB4-STAB.
    WB4-SDV = 'A'.
    WB4-SDV+1 = TB4-SDV.
    WB4-NOTEXIST = 'Y'.
    APPEND WB4 TO IB4.
    TB4-FLDLIST = ''.
    EXIT.
  ENDIF.

* Search for language field in table
  SELECT        COUNT( * )
           INTO NUMREC
           FROM DD03L
          WHERE TABNAME    = TABNAME
            AND DOMNAME    = 'SPRAS'
            AND KEYFLAG    = 'X'
            AND AS4LOCAL   = 'A'.

  CASE NUMREC.
    WHEN 1.
      SELECT SINGLE FIELDNAME
               INTO LANGFIELD
               FROM DD03L
              WHERE TABNAME    = TABNAME
                AND DOMNAME    = 'SPRAS'
                AND KEYFLAG    = 'X'
                AND AS4LOCAL   = 'A'.

    WHEN OTHERS.
      LANGFIELD = ''.
  ENDCASE.

  CLEAR WB5.

* Search for related text table
  SELECT        CHECKTABLE
                FORTABLE
                FORKEY
                AS4VERS
           INTO (WB5-CHECKTABLE
                ,WB5-FORTABLE
                ,WB5-FORKEY
                ,DUMMYORDER
                )
           FROM DD08VV
          WHERE CHECKTABLE = TABNAME
            AND FRKART     = 'TEXT'
            AND AS4LOCAL   = 'A'
            AND CHECKTABLE <> 'T002'
            AND FORTABLE   <> TABNAME
       ORDER BY AS4VERS DESCENDING.

*   Text table must exist
    SELECT        COUNT( * )
             INTO NUMREC
             FROM DD02L
            WHERE TABNAME = WB5-FORTABLE
              AND AS4VERS = 'A'
              AND TABCLASS <> 'INTTAB'.

    IF SY-SUBRC = 4.
      TABNAMETEXT = ''.
    ELSE.
*     Text table field must exist
      SELECT        COUNT( * )
               INTO NUMREC
               FROM DD03L
              WHERE TABNAME   = WB5-CHECKTABLE
                AND FIELDNAME = WB5-FORKEY
                AND AS4LOCAL  = 'A'.
      IF NUMREC = 0.
        TABNAMETEXT = ''.
      ELSE.
        TABNAMETEXT = WB5-FORTABLE.
        APPEND WB5 TO IB5.
      ENDIF.
    ENDIF.
  ENDSELECT.

  IF SY-SUBRC = 4 OR TABNAMETEXT = ''.
    TABNAMETEXT = ''.
  ELSE.

*   Check if table has any fields of type rawstring/string
    SELECT        COUNT( * )
             INTO NUMREC
             FROM DD03L
            WHERE TABNAME    = TABNAMETEXT
              AND ( DATATYPE = 'RAWSTRING'
                OR  DATATYPE = 'RSTR'
                OR  DATATYPE = 'STRG' )
              AND AS4LOCAL   = 'A'.

    IF NUMREC = 0.

*     Check if table is already added
      READ TABLE IB4 WITH KEY TABNAME = TABNAMETEXT
                     TRANSPORTING NO FIELDS.

      IF SY-SUBRC <> 0.
*       Getting text language field
        SELECT        COUNT( * )
                 INTO NUMREC
                 FROM DD03L
                WHERE TABNAME    = TABNAMETEXT
                  AND DOMNAME    = 'SPRAS'
                  AND KEYFLAG    = 'X'
                  AND AS4LOCAL   = 'A'.

        IF NUMREC = 1.
          SELECT SINGLE FIELDNAME
                   INTO LANGFIELDTEXT
                   FROM DD03L
                  WHERE TABNAME    = TABNAMETEXT
                    AND DOMNAME    = 'SPRAS'
                    AND KEYFLAG    = 'X'
                    AND AS4LOCAL   = 'A'.
        ELSE.
          LANGFIELDTEXT = ''.
        ENDIF.

        SELECT SINGLE DDTEXT
                 INTO TABTEXT
                 FROM DD02T
                WHERE TABNAME  = TABNAMETEXT
                  AND DDLANGUAGE = SY-LANGU
                  AND AS4LOCAL = 'A'.

        CLEAR WB4.
        WB4-FTYPE = TB4-FTYPE.
        WB4-TABNAME = TABNAMETEXT.
        WB4-TABTEXT = TABTEXT.
        WB4-LANGFIELD = LANGFIELDTEXT.
        WB4-TABNAMETEXT = ''.
        WB4-LANGFIELDTEXT = ''.
        WB4-SCHEMA = TB4-SCHEMA.
        WB4-QUERIES = TB4-QUERIES.
        WB4-LIMIT = TB4-LIMIT.
        WB4-MANDATORY = TB4-MANDATORY.
        WB4-CLIENT = TB4-CLIENT.
        WB4-FFSD = TB4-FFSD.
        WB4-FAGF = TB4-FAGF.
        WB4-STAB = 'A'.
        WB4-STAB+1 = TB4-STAB.
        WB4-SDV = 'A'.
        WB4-SDV+1 = TB4-SDV.
        APPEND WB4 TO IB4.
      ENDIF.
    ENDIF.
  ENDIF.


  SELECT SINGLE DDTEXT
           INTO TABTEXT
           FROM DD02T
          WHERE TABNAME  = TABNAME
            AND DDLANGUAGE = SY-LANGU
            AND AS4LOCAL = 'A'.

* Adding newly selected table
  CLEAR WB4.
  WB4-FTYPE = TB4-FTYPE.
  WB4-TABNAME = TABNAME.
  WB4-TABTEXT = TABTEXT.
  WB4-LANGFIELD = LANGFIELD.
  WB4-TABNAMETEXT = TABNAMETEXT.
  WB4-LANGFIELDTEXT = LANGFIELDTEXT.
  WB4-SCHEMA = TB4-SCHEMA.
  WB4-QUERIES = TB4-QUERIES.
  WB4-LIMIT = TB4-LIMIT.
  WB4-GENERATE = TB4-GENERATE.
  WB4-MANDATORY = TB4-MANDATORY.
  WB4-CLIENT = TB4-CLIENT.
  WB4-FFSD = TB4-FFSD.
  WB4-FAGF = TB4-FAGF.
  WB4-STAB = 'A'.
  WB4-STAB+1 = TB4-STAB.
  WB4-SDV = 'A'.
  WB4-SDV+1 = TB4-SDV.
  IF TB4-FLDLIST <> ''.
    CONCATENATE '#' TB4-FLDLIST '#'
                INTO WB4-FLDLIST.
  ELSE.
    WB4-FLDLIST = ''.
  ENDIF.
  APPEND WB4 TO IB4.

  TB4-FLDLIST = ''.
ENDFORM.                                                    "ADDB45

*---------------------------------------------------------------------*
*      Form  GENDYNAMICSHARED                                         *
*---------------------------------------------------------------------*
FORM GENDYNAMICSHARED CHANGING NUMCHAR.
  DATA: LENG(10) TYPE N.

  PERFORM C1 USING ''.
  PERFORM C1 USING 'DATA: BEGIN OF TOUT'.

  LOOP AT IDD03L ASSIGNING <ZDD03L>.
    IF <ZDD03L>-DATATYPE = 'RAW'.
      LENG = <ZDD03L>-LENG * 4.
    ELSEIF <ZDD03L>-DATATYPE = 'DEC' OR  <ZDD03L>-DATATYPE = 'CURR'.
      LENG = <ZDD03L>-LENG + <ZDD03L>-DECIMALS + 5.
    ELSE.
      LENG = <ZDD03L>-LENG.
    ENDIF.

    IF LENG > 255.
      LENG = 255.
    ENDIF.

    NUMCHAR = NUMCHAR + LENG.

    CONCATENATE <ZDD03L>-FIELDNAME '(' LENG ')'
                INTO TXT2STR.
    CONDENSE TXT2STR NO-GAPS.
    CONCATENATE '      ,' TXT2STR
           INTO CONCAT.
    PERFORM C2 USING CONCAT 'TYPE C'.
  ENDLOOP.

  PERFORM C1 USING '      ,END OF TOUT.'.
  PERFORM C1 USING ''.
ENDFORM.                    "GENDYNAMICSHARED

*---------------------------------------------------------------------*
*       FORM GENDYNAMICFORM                                           *
*---------------------------------------------------------------------*
FORM GENDYNAMICFORM USING
                     PARFTYPE
                     PARTABNAME
                     PARTABTEXT
                     PARLANGFIELD
                     PARTABNAMETEXT
                     PARLANGFIELDTEXT
                     PARLIMIT
                     PARGEN
                     PARMANDATORY
                     PARCLIENT
                     PARFFSD
                     PARFAGF
                     PARSDV
                     PARSTAB
                     PARTOOBIG
                     PARNOTEXIST
                     PARNOTSELECTED
                     PARFLDLIST.

  DATA: LIMIT TYPE I
       ,NUMFLD(5) TYPE N
       ,WHEREEXPR(4000) TYPE C.

  LIMIT = PARLIMIT.

  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING '*       FORM EXPB3                               *'.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING 'FORM EXPB3.'.

  IF PARNOTEXIST = ''.
    NUMFLD = 0.
    LOOP AT IDD03L ASSIGNING <ZDD03L>.
      NUMFLD = NUMFLD + 1.

      PERFORM C2 USING '  PERFORM EXPB3X USING ' NUMFLD.
      PERFORM D3 USING '                       ''' <ZDD03L>-FIELDNAME
                       ''''.
      PERFORM C1 USING '                       TABNAME.'.
    ENDLOOP.
  ENDIF.

  PERFORM C1 USING 'ENDFORM.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING '*       FORM EXPB45                              *'.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING 'FORM EXPB45.'.
  PERFORM C1 USING '  PERFORM EXPB4REC USING'.
  PERFORM D3 USING '                   ''' WEXP-TABNAME ''''.
  PERFORM D3 USING '                   ''' WEXP-TABTEXT ''''.
  PERFORM D3 USING '                   ''' PARLANGFIELD ''''.
  PERFORM D3 USING '                   ''' PARTABNAMETEXT ''''.
  PERFORM D3 USING '                   ''' PARLANGFIELDTEXT ''''.
  PERFORM D3 USING '                   ''' PARLIMIT ''''.
  PERFORM D3 USING '                   ''' PARMANDATORY ''''.
  PERFORM D3 USING '                   ''' PARCLIENT ''''.
  PERFORM D3 USING '                   ''' PARFFSD ''''.
  PERFORM D3 USING '                   ''' PARFAGF ''''.
  PERFORM D3 USING '                   ''' PARSDV ''''.
  PERFORM D3 USING '                   ''' PARSTAB ''''.
  PERFORM D3 USING '                   ''' PARTOOBIG ''''.
  PERFORM D3 USING '                   ''' PARNOTEXIST ''''.
  PERFORM D3 USING '                   ''' PARNOTSELECTED ''''.
  PERFORM C1 USING '                   SREC.'.
  PERFORM C1 USING ''.
  LOOP AT IB5 ASSIGNING <ZB5> WHERE CHECKTABLE = WEXP-TABNAME.
      PERFORM C1 USING '  PERFORM EXPB5REC USING '.
      PERFORM C3 USING '                   ''' <ZB5>-CHECKTABLE ''''.
      PERFORM C3 USING '                   ''' <ZB5>-FORTABLE   ''''.
      PERFORM C3 USING '                   ''' <ZB5>-FORKEY     '''.'.
  ENDLOOP.
  PERFORM C1 USING 'ENDFORM.'.
  PERFORM C1 USING ''.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING '*       FORM PROC                                *'.
  PERFORM C1 USING '*------------------------------------------------*'.
  PERFORM C1 USING 'FORM PROC.'.
  PERFORM C1 USING '  PERFORM STARTDOWNLOAD.'.

  IF GENERROR = ABAP_TRUE.
*   GENERATE: CLOSE & COMMIT
*   ========================
    PERFORM C1 USING '  PERFORM ENDDOWNLOAD.'.

*   GENERATE: END
*   =============
    PERFORM C1 USING 'ENDFORM.'.
    EXIT.
  ENDIF.

  PERFORM C1 USING ''.

  IF PARTOOBIG = '' AND  PARNOTEXIST = '' AND  PARNOTSELECTED = ''.

*   ws definition
*   =============
    PERFORM D3 USING '  DATA: TABNAME TYPE DD03L-ROLLNAME VALUE '''
                              PARTABNAME ''','.
    PERFORM C1 USING '        LO_DYNAMIC_TABLE TYPE REF TO DATA, '.
    PERFORM C1 USING '        LO_DYNAMIC_LINE TYPE REF TO DATA. '.
    PERFORM C1 USING '  FIELD-SYMBOLS: <FS_TABLE> TYPE TABLE, '.
    PERFORM C1 USING '                 <FS> TYPE ANY.'.
    PERFORM C1 USING ''.

*   create dynamic structure
*   ========================
    PERFORM D2 USING '  CREATE DATA LO_DYNAMIC_TABLE'
                     ' TYPE TABLE OF (TABNAME).'.
    PERFORM C1 USING '  ASSIGN LO_DYNAMIC_TABLE->* TO <FS_TABLE>.'.

    PERFORM D2 USING '  CREATE DATA LO_DYNAMIC_LINE'
                     ' LIKE LINE OF <FS_TABLE>.'.
    PERFORM C1 USING '  ASSIGN LO_DYNAMIC_LINE->* TO <FS>.'.

*   GENERATE: SELECT
*   ================

    IF PARTABNAME <> 'TRDIR' AND
       PARTABNAME <> 'USOBX' AND
       PARTABNAME <> 'USOBX_C'.

*     select
*     ======
      PERFORM C1 USING '  SELECT * '.
      PERFORM C1 USING '           INTO TABLE <FS_TABLE>'.
      PERFORM C1 USING '           PACKAGE SIZE 100'.

*     from
*     ====
      PERFORM C1 USING '           FROM  (TABNAME)'.
      IF ( PARCLIENT = 'C' AND PSTDALL = 'X' ).
        PERFORM C1 USING '                CLIENT SPECIFIED'.
      ENDIF.

*     where
*     =====
      IF PARGEN = 'WHERE'.
        PERFORM C1 USING '          WHERE'.

        PERFORM GENVARCODE USING PARTABNAME CHANGING WHEREEXPR.

        PERFORM C1 USING WHEREEXPR.

        IF PARLANGFIELD <> '' AND PARTABNAME <> 'AGR_PROF'.
          PERFORM C3 USING '            and' PARLANGFIELD
                           '= SY-LANGU'.
        ENDIF.

      ELSE.
        IF PARLANGFIELD <> '' AND PARTABNAME <> 'AGR_PROF'.
          PERFORM C3 USING '          WHERE' PARLANGFIELD
                           '= SY-LANGU'.
        ENDIF.
      ENDIF.

      PERFORM C1 USING '          .'.
      PERFORM C1 USING '    LOOP AT <FS_TABLE> ASSIGNING <FS>.'.

      PERFORM C3 USING '      MOVE-CORRESPONDING' '<FS>' 'to TOUT.'.

    ELSE.
*     select
*     ======
      PERFORM C1 USING ' SELECT * '.
      PERFORM C1 USING '           INTO <FS>'.

*     from
*     ====
      PERFORM C1 USING '           FROM  (TABNAME)'.
      IF ( PARCLIENT = 'C' AND PSTDALL = 'X' ).
        PERFORM C1 USING '                CLIENT SPECIFIED'.
      ENDIF.

*     where
*     =====
      IF PARGEN = 'WHERE'.
        PERFORM C1 USING '          WHERE'.

        PERFORM GENVARCODE USING PARTABNAME CHANGING WHEREEXPR.

        PERFORM C1 USING WHEREEXPR.

        IF PARLANGFIELD <> '' AND PARTABNAME <> 'AGR_PROF'.
          PERFORM C3 USING '            and' PARLANGFIELD
                           '= SY-LANGU'.
        ENDIF.

      ELSE.
        IF PARLANGFIELD <> '' AND PARTABNAME <> 'AGR_PROF'.
          PERFORM C3 USING '          WHERE' PARLANGFIELD
                           '= SY-LANGU'.
        ENDIF.
      ENDIF.

      PERFORM C1 USING '          .'.
      PERFORM C1 USING '    MOVE-CORRESPONDING <FS> to TOUT.'.
    ENDIF.

*   GENERATE: SELECT: FIELD PROCESSING
*   ==================================

    NUMFLD = 0.

    LOOP AT IDD03L ASSIGNING <ZDD03L>.
      NUMFLD = NUMFLD + 1.

      IF <ZDD03L>-FIELDNAME = 'BNAME' OR
         <ZDD03L>-FIELDNAME = 'UNAME' OR
         <ZDD03L>-FIELDNAME = 'REFUSER' OR
         <ZDD03L>-FIELDNAME = 'AGR_NAME' OR
         <ZDD03L>-FIELDNAME = 'CHILD_AGR' OR
         <ZDD03L>-FIELDNAME = 'PARENT_AGR' OR
         <ZDD03L>-FIELDNAME = 'PROFILE' OR
         <ZDD03L>-FIELDNAME = 'PROFN' OR
         <ZDD03L>-FIELDNAME = 'OBJCT' OR
         <ZDD03L>-FIELDNAME = 'AUTH'.
        CONCATENATE 'TOUT-' <ZDD03L>-FIELDNAME '+0(1)'
                    INTO CONCATU.
        PERFORM C3 USING '        IF' CONCATU '= '' ''.'.
        PERFORM C3 USING ' ' CONCATU '= ''_''.'.
        PERFORM C1 USING '        ENDIF.'.
      ENDIF.
    ENDLOOP.

    IF NUMFLD = 1.
      PERFORM C1 USING '      PERFORM CHARFIELDREPL USING '.
      PERFORM D3 USING '            TOUT-' <ZDD03L>-FIELDNAME '.'.
      CONCATENATE '      MOVE TOUT-' <ZDD03L>-FIELDNAME
                  INTO CONCATU.
      PERFORM C2 USING CONCATU 'TO TREC.'.
    ELSE.
      PERFORM C1 USING '      PERFORM CHARFIELDREPL USING TOUT.'.
      PERFORM C1 USING ''.
      PERFORM C1 USING '      CONCATENATE'.

      LOOP AT IDD03L ASSIGNING <ZDD03L>.
        IF PSTDUSR = 'X'.
          PERFORM D2 USING '        TOUT-' <ZDD03L>-FIELDNAME.
        ELSE.
          IF ( PARTABNAME = 'ADRP'
                 AND <ZDD03L>-FIELDNAME = 'NAME_FIRST' ) OR
             ( PARTABNAME = 'ADRP'
                 AND <ZDD03L>-FIELDNAME = 'NAME_LAST' ) OR
             ( PARTABNAME = 'ADRP'
                 AND <ZDD03L>-FIELDNAME = 'NAME_TEXT' ) OR
             ( PARTABNAME = 'ADCP'
                 AND <ZDD03L>-FIELDNAME = 'DEPARTMENT' ) OR
             ( PARTABNAME = 'ADCP'
                 AND <ZDD03L>-FIELDNAME = 'FUNCTION' ) OR
             ( PARTABNAME = 'USR03'
                 AND <ZDD03L>-FIELDNAME = 'NAME1' ).
            PERFORM D2 USING '        ''Hidden''' ''.
          ELSEIF
             ( PARTABNAME = 'USR03'
                 AND <ZDD03L>-FIELDNAME <> 'MANDT'
                 AND <ZDD03L>-FIELDNAME <> 'BNAME' ).
            PERFORM D2 USING '        ''''' ''.
          ELSE.
            PERFORM D2 USING '        TOUT-' <ZDD03L>-FIELDNAME.
          ENDIF.
        ENDIF.
      ENDLOOP.

      PERFORM C1 USING '        INTO TREC'.
      PERFORM C1 USING '        SEPARATED BY TRANSHS.'.
      PERFORM C1 USING ''.
    ENDIF.

    PERFORM C1 USING '      PERFORM FILETRANSFER'.
    PERFORM C1 USING '              USING    FTYPE'.
    PERFORM C1 USING '              CHANGING FNO FBYTE FREC SREC.'.

*   GENERATE: SELECT: ENDSELECT
*   ===========================

    IF PARTABNAME <> 'TRDIR' AND
       PARTABNAME <> 'USOBX' AND
       PARTABNAME <> 'USOBX_C'.

      PERFORM C1 USING '    ENDLOOP.'.
      PERFORM C1 USING ''.
    ENDIF.

    PERFORM C1 USING '  ENDSELECT.'.
    PERFORM C1 USING ''.

  ENDIF.

*   GENERATE: CLOSE & COMMIT
*   ========================
  PERFORM C1 USING '  PERFORM ENDDOWNLOAD.'.

*   GENERATE: END
*   =============

  PERFORM C1 USING 'ENDFORM.'.
ENDFORM.                    "GENDYNAMICFORM

*---------------------------------------------------------------------*
*       FORM GETTABLEFIELDS                                           *
*---------------------------------------------------------------------*
FORM GETTABLEFIELDS USING PARTABNAME PARFLDLIST.
  DATA: FLDSEARCH(32) TYPE C.

  SELECT        DATATYPE
                FIELDNAME
                LENG
                POSITION
                DECIMALS
           INTO (WDD03L-DATATYPE
                ,WDD03L-FIELDNAME
                ,WDD03L-LENG
                ,WDD03L-POSITION
                ,WDD03L-DECIMALS
                )
           FROM DD03L
          WHERE TABNAME  = PARTABNAME
            AND AS4LOCAL = 'A'
       ORDER BY POSITION.

    IF PARFLDLIST <> ''.
      CONCATENATE '#' WDD03L-FIELDNAME '#'
                  INTO FLDSEARCH.

      SEARCH PARFLDLIST FOR FLDSEARCH.

      IF SY-SUBRC <> 0.
        CONTINUE.
      ENDIF.
    ENDIF.

    IF WDD03L-FIELDNAME+0(1) <> '.'.
      APPEND WDD03L TO IDD03L.
    ENDIF.
  ENDSELECT.
ENDFORM.                    "GETTABLEFIELDS

*---------------------------------------------------------------------*
*       FORM GENVARCODE                                               *
*---------------------------------------------------------------------*
FORM GENVARCODE USING TABNAME CHANGING WHERECLAUSE.
  CASE TABNAME.
    WHEN 'DD02V'.
      WHERECLAUSE = '                TABCLASS <> ''INTTAB'''.

    WHEN 'DD02L'.
      CONCATENATE
                  '                  AS4LOCAL = ''A'''
                  '              AND TABCLASS <> ''INTTAB'''
                  INTO WHERECLAUSE
                  SEPARATED BY SPACE.

    WHEN 'DD09L'.
      WHERECLAUSE = '                AS4LOCAL = ''A'''.

    WHEN 'PAHI'.
      WHERECLAUSE = '                PARTYPE = ''S'''.

    WHEN 'TADIR'.
      CONCATENATE
                  '                  OBJECT <> ''DTEL'''
                  '              AND OBJECT <> ''DSYS'''
                  '              AND OBJECT <> ''DOMA'''
                  '              AND OBJECT <> ''FUGR'''
                  '              AND OBJECT <> ''DOCV'''
                  '              AND OBJECT <> ''DOCT'''
                  INTO WHERECLAUSE
                  SEPARATED BY SPACE.

    WHEN 'V_E071EU'.
      CONCATENATE
                  '                  AS4DATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'TPLOG'.
      CONCATENATE
                  '                  SYDATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'USOBX_CD'.
      CONCATENATE
                  '                  MODDATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'USOBT_CD'.
      CONCATENATE
                  '                  MODDATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'DDPRS'.
      WHERECLAUSE = '                PROTNAME = ''TRLOGSYSTEM'''.

    WHEN 'USH10'.
      CONCATENATE
                  '                  MODDA >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'USH12'.
      CONCATENATE
                  '                  MODDA >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'SE16N_CD_KEY'.
      CONCATENATE
                  '                  SDATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN 'UASE16N_CD_KEY'.
      CONCATENATE
                  '                  SDATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.


    WHEN 'AUSP'.
      CONCATENATE ''
                  '                  KLART = ''032'''
                  INTO WHERECLAUSE.


    WHEN 'DD03M'.
      CONCATENATE
                  'TABNAME in (''CEKKO'',''CEBAN'',''CESSR'')'
                  ' AND FLDSTAT = ''A'''
                  ' AND ROLLSTAT = ''A'''
                  ' AND DOMSTAT = ''A'''
                  ' AND TEXTSTAT = ''A'''
                  ' AND DDLANGUAGE = ''EN'''
                  INTO WHERECLAUSE
                  SEPARATED BY SPACE.

    WHEN 'E070' OR 'E070V'.
      CONCATENATE
                  '                  AS4DATE >= ''' PDATE ''''
                  INTO WHERECLAUSE.

    WHEN OTHERS.
      CONCATENATE 'Programming error in genvarcode case!'
                  TABNAME
                  INTO CONCAT
                  SEPARATED BY SPACE.
      PERFORM EXPB1REC USING 'VARCODE' 'E' 'C' CONCAT.
  ENDCASE.
ENDFORM.                    "GENVARCODE

