*---------------------------------------------------------------------*
*       FORM GETDYNOBJFLD                                             *
*---------------------------------------------------------------------*
FORM GETDYNOBJFLD.
  TB4-FTYPE = 'O'.
  TB4-QUERIES = 'Y'.
  TB4-LIMIT = STDLIMIT.
  TB4-GENERATE = ''.
  TB4-MANDATORY = ''.
  TB4-CLIENT = ''.
  TB4-FFSD = ''.
  TB4-FAGF = ''.
  TB4-SDV = ''.
  TB4-STAB = ''.

  DATA: FLD LIKE TOBJ-FIEL1
       ,FLG(20) TYPE C
       ,DOMNAME TYPE DD04L-DOMNAME
       ,ENTITYTAB TYPE DD01L-ENTITYTAB.

  DATA: BEGIN OF WDD03M
       ,FIELDNAME TYPE DD03M-FIELDNAME
       ,TABNAME TYPE DD03M-TABNAME
       ,CHECKTABLE TYPE DD03M-CHECKTABLE
       ,ROLLNAME TYPE DD03M-ROLLNAME
       ,ENTITYTAB TYPE DD03M-ENTITYTAB
       ,DOMNAME TYPE DD03M-DOMNAME
       ,DDTEXT TYPE DD03M-DDTEXT
       ,DDLANGUAGE TYPE DD03M-DDLANGUAGE
       ,END OF WDD03M
       ,IDD03M LIKE TABLE OF WDD03M.
  FIELD-SYMBOLS <ZDD03M> LIKE LINE OF IDD03M.

  SELECT      FIELDNAME
              TABNAME
              CHECKTABLE
              ROLLNAME
              ENTITYTAB
              DOMNAME
              DDTEXT
              DDLANGUAGE
         INTO TABLE
              IDD03M
         FROM DD03M
        WHERE TABNAME IN ('AUTHA','AUTHB','AUTHBIW')
          AND FLDSTAT    = 'A'
          AND ROLLSTAT   = 'A'
          AND DOMSTAT    = 'A'
          AND TEXTSTAT   = 'A'.

  SELECT        OBJCT
                FIEL1
                FIEL2
                FIEL3
                FIEL4
                FIEL5
                FIEL6
                FIEL7
                FIEL8
                FIEL9
                FIEL0
                OCLSS
           INTO TABLE
                ITOBJ
   PACKAGE SIZE 1000
           FROM TOBJ.

    LOOP AT ITOBJ ASSIGNING <ZTOBJ>.
      DO 10 TIMES VARYING FLD FROM <ZTOBJ>-FIEL1 NEXT <ZTOBJ>-FIEL2.
        IF FLD = ''.
          CONTINUE.
        ENDIF.

        READ TABLE IDD03M
            WITH KEY TABNAME    = 'AUTHA'
                     FIELDNAME  = FLD
                     DDLANGUAGE = SY-LANGU
           ASSIGNING <ZDD03M>.

        IF SY-SUBRC <> 0.
          READ TABLE IDD03M
              WITH KEY TABNAME    = 'AUTHA'
                       FIELDNAME  = FLD
             ASSIGNING <ZDD03M>.
        ENDIF.

        IF SY-SUBRC <> 0.
          READ TABLE IDD03M
              WITH KEY TABNAME    = 'AUTHB'
                       FIELDNAME  = FLD
                       DDLANGUAGE = SY-LANGU
             ASSIGNING <ZDD03M>.
        ENDIF.

        IF SY-SUBRC <> 0.
          READ TABLE IDD03M
              WITH KEY TABNAME    = 'AUTHB'
                       FIELDNAME  = FLD
             ASSIGNING <ZDD03M>.
        ENDIF.

        IF SY-SUBRC <> 0.
          READ TABLE IDD03M
              WITH KEY TABNAME    = 'AUTHBIW'
                       FIELDNAME  = FLD
                       DDLANGUAGE = SY-LANGU
             ASSIGNING <ZDD03M>.
        ENDIF.

        IF SY-SUBRC <> 0.
          READ TABLE IDD03M
              WITH KEY TABNAME    = 'AUTHBIW'
                       FIELDNAME  = FLD
             ASSIGNING <ZDD03M>.
        ENDIF.

        IF SY-SUBRC <> 0.
           CONTINUE.
        ENDIF.

        CASE <ZTOBJ>-OCLSS.
          WHEN 'AAAB'.          FLG = ' X'.
                                TB4-SCHEMA = 'CROSS_APP'.
          WHEN 'AM'.            FLG = '      X'.
                                TB4-SCHEMA = 'ASSET'.
          WHEN 'BC_A'.          FLG = 'X'.
                                TB4-SCHEMA = 'BASIS'.
          WHEN 'BC_C'.          FLG = 'X'.
                                TB4-SCHEMA = 'BASIS'.
          WHEN 'BC_Z'.          FLG = 'X'.
                                TB4-SCHEMA = 'BASIS'.
          WHEN 'CLAS'.          FLG = ' X'.
                                TB4-SCHEMA = 'CLASSIFICATION'.
          WHEN 'CO'.            FLG = '         XX'.
                                TB4-SCHEMA = 'CONTROLLING'.
          WHEN 'COND'.          FLG = '    X'.
                                TB4-SCHEMA = 'CONDITION'.
          WHEN 'CV'.            FLG = ' X'.
                                TB4-SCHEMA = 'DOCUMENT_MGMT'.
          WHEN 'ECCS'.          FLG = '  X'.
                                TB4-SCHEMA = 'CONSOLIDATION'.
          WHEN 'EDI'.           FLG = ' X'.
                                TB4-SCHEMA = 'EDI'.
          WHEN 'FI'.            FLG = '  X'.
                                TB4-SCHEMA = 'FINANCE'.
          WHEN 'FI_T'.          FLG = '        X'.
                                TB4-SCHEMA = 'TREASURY'.
          WHEN 'HR'.            FLG = '       X'.
                                TB4-SCHEMA = 'HR'.
          WHEN 'IM'.            FLG = '  X'.
                                TB4-SCHEMA = 'INVESTMENT_MGMT'.
          WHEN 'IS'.            FLG = '                X'.
                                TB4-SCHEMA = 'IS'.
          WHEN 'IS-B'.          FLG = '                X'.
                                TB4-SCHEMA = 'IS_BANKING'.
          WHEN 'IS_B'.          FLG = '                X'.
                                TB4-SCHEMA = 'IS_BANKING'.
          WHEN 'ISRE'.          FLG = '                X'.
                                TB4-SCHEMA = 'IS_REAL_ESTATE'.
          WHEN 'IS_H'.          FLG = '                X'.
                                TB4-SCHEMA = 'IS_HOSPITAL'.
          WHEN 'IS_P'.          FLG = '                X'.
                                TB4-SCHEMA = 'IS_PUBLISHING'.
          WHEN 'LC'.            FLG = '          X'.
                                TB4-SCHEMA = 'LOGISTICS'.
          WHEN 'LE_L'.          FLG = '     X'.
                                TB4-SCHEMA = 'LOGISTICS'.
          WHEN 'LE_T'.          FLG = '    X'.
                                TB4-SCHEMA = 'LOGISTICS'.
          WHEN 'LE_V'.          FLG = '    X'.
                                TB4-SCHEMA = 'LOGISTICS'.
          WHEN 'LO'.            FLG = '   XXX'.
                                TB4-SCHEMA = 'LOGISTICS'.
          WHEN 'MM_B'.          FLG = '     X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_D'.          FLG = '   X X      X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_E'.          FLG = '   X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_G'.          FLG = '   XXX      X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_L'.          FLG = '     X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_R'.          FLG = '  XX'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_S'.          FLG = '     X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'MM_W'.          FLG = '  X  X'.
                                TB4-SCHEMA = 'MATERIALS_MGMT'.
          WHEN 'PM'.            FLG = '           X'.
                                TB4-SCHEMA = 'PLANT_MAINT'.
          WHEN 'PP'.            FLG = '            X'.
                                TB4-SCHEMA = 'PRODUCTION_PLAN'.
          WHEN 'PS'.            FLG = '              X'.
                                TB4-SCHEMA = 'PROJECT'.
          WHEN 'QA'.            FLG = '             X'.
                                TB4-SCHEMA = 'QUALITY'.
          WHEN 'SD'.            FLG = '    X'.
                                TB4-SCHEMA = 'SALES_DISTRIBUTION'.
          WHEN 'TRTM'.          FLG = '        X'.
                                TB4-SCHEMA = 'TREASURY'.
          WHEN 'WCM'.           FLG = ' X'.
                                TB4-SCHEMA = 'WORK CLEARANCE'.
          WHEN 'WF'.            FLG = ' X'.
                                TB4-SCHEMA = 'WORKFLOW'.
          WHEN 'WG'.            FLG = '                 X'.
                                TB4-SCHEMA = 'RETAIL'.
          WHEN OTHERS.          FLG = ''.
                                TB4-SCHEMA = 'OTHER'.
        ENDCASE.


        CASE <ZDD03M>-CHECKTABLE.
          WHEN '*'.
            SELECT        DOMNAME
                     INTO DOMNAME
                     FROM DD04L
                    WHERE ROLLNAME = <ZDD03M>-ROLLNAME
                      AND AS4LOCAL   = 'A'.

              SELECT        ENTITYTAB
                       INTO ENTITYTAB
                       FROM DD01L
                      WHERE DOMNAME = DOMNAME
                        AND AS4LOCAL   = 'A'.
                TB4-SDV = FLG.
                PERFORM ADDB45 USING ENTITYTAB.
              ENDSELECT.
            ENDSELECT.

          WHEN ''.

          WHEN OTHERS.
            TB4-SDV = FLG.
            PERFORM ADDB45 USING <ZDD03M>-CHECKTABLE.
        ENDCASE.
      ENDDO.
    ENDLOOP.
  ENDSELECT.
ENDFORM.
