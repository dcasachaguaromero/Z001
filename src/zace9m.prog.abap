*---------------------------------------------------------------------*
*       FORM GETDYNAUTHGRP                                            *
*---------------------------------------------------------------------*
FORM GETDYNAUTHGRP.
  DATA: TAB TYPE DD03L-TABNAME.

  DATA: BEGIN OF WAUTHTAB
       ,TABNAME TYPE DD03L-TABNAME
       ,END OF WAUTHTAB
       ,IAUTHTAB LIKE TABLE OF WAUTHTAB.

  TB4-FTYPE = 'O'.
  TB4-SCHEMA = 'OTHER'.
  TB4-QUERIES = 'Y'.
  TB4-LIMIT = STDLIMIT.
  TB4-GENERATE = ''.
  TB4-MANDATORY = ''.
  TB4-CLIENT = ''.
  TB4-FFSD = ''.
  TB4-FAGF = 'Y'.
  TB4-SDV = ''.
  TB4-STAB = ''.

  SELECT        TABNAME
           INTO CORRESPONDING FIELDS OF
          TABLE IAUTHTAB
           FROM DD03L
          WHERE DOMNAME IN ('BRGRU'
                           ,'BERGR'
                           ,'BEGRU'
                           ,'P_GROUP'
                           ,'IAUTG'
                           ,'FC_AGDEF'
                           ,'FS_BRGRU'
                           )
            AND AS4LOCAL   = 'A'."#EC CI_NO_TRANSFORM

  SELECT        TABNAME
      APPENDING CORRESPONDING FIELDS OF
          TABLE IAUTHTAB
           FROM DD03L
          WHERE FIELDNAME IN ('SECU'
                             ,'CVBRG'
                             )
            AND AS4LOCAL   = 'A'.

  SELECT        TABNAME
      APPENDING CORRESPONDING FIELDS OF
          TABLE IAUTHTAB
           FROM DD03L
          WHERE ROLLNAME IN ('SECU'
                            ,'AUTGR'
                            ,'BGRKL'
                            ,'BGRSE'
                            ,'BGRKP'
                            )
            AND AS4LOCAL   = 'A'.

    SELECT      TABNAME
           INTO TAB
           FROM DD02L
                FOR ALL ENTRIES IN IAUTHTAB
          WHERE TABNAME = IAUTHTAB-TABNAME
            AND TABCLASS IN ('POOL'
                            ,'TRANSP'
                            ,'CLUSTER'
                            )
            AND AS4LOCAL   = 'A'."#EC CI_NO_TRANSFORM
      IF TAB <> 'BSEC'.
        PERFORM ADDB45 USING TAB.
      ELSE.
        CONCATENATE 'Information: Table BSEC not downloaded during'
                    'Authorisation Group table determination'
               INTO TXTSTR
               SEPARATED BY space.
        PERFORM EXPB1REC USING 'GETDYNAUTHGRP' 'I' 'C' TXTSTR.
      ENDIF.
    ENDSELECT.
ENDFORM.
