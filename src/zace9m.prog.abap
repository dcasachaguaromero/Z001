*---------------------------------------------------------------------*
*       FORM EXPDYNAMIC                                               *
*---------------------------------------------------------------------*
FORM EXPDYNAMIC.
  DATA: CONDFLD(4000) TYPE C
       ,WHEREEXPR(4000) TYPE C
       ,NUMCHAR(20) TYPE N
       ,NUMREC TYPE I
       ,NNUM(12) TYPE N
       ,CALCBYTE(16) TYPE P.

  LOOP AT IB4 ASSIGNING <ZB4>.

    GENERROR = ABAP_FALSE.

    WEXP-LOCATION = 'EXPDYNAMIC'.
    WEXP-DOWNLOAD = 'Y'.
    WEXP-FTYPE = <ZB4>-FTYPE.
    WEXP-TABNAME = <ZB4>-TABNAME.
    WEXP-TABTEXT = <ZB4>-TABTEXT.
    WEXP-SCHEMA = <ZB4>-SCHEMA.
    WEXP-QUERIES = <ZB4>-QUERIES.
    WEXP-GEN = <ZB4>-GENERATE.
    WEXP-FLDLST = <ZB4>-FLDLIST.

    PERFORM GENCONSTSTART.

*   SELECTED - NOTSELECTED FLAG

    <ZB4>-NOTSELECTED = 'Y'.

    IF <ZB4>-MANDATORY = 'Y'.
      <ZB4>-NOTSELECTED  = ''.
    ENDIF.
    IF <ZB4>-FFSD = 'Y' AND PSTDFSD = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ENDIF.
    IF <ZB4>-FAGF = 'Y' AND PSTDAGF = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ENDIF.

    IF PSTDD01 = 'X' AND <ZB4>-SDV+1(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD02 = 'X' AND <ZB4>-SDV+2(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD03 = 'X' AND <ZB4>-SDV+3(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD04 = 'X' AND <ZB4>-SDV+4(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD05 = 'X' AND <ZB4>-SDV+5(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD06 = 'X' AND <ZB4>-SDV+6(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD07 = 'X' AND <ZB4>-SDV+7(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD08 = 'X' AND <ZB4>-SDV+8(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD09 = 'X' AND <ZB4>-SDV+9(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD10 = 'X' AND <ZB4>-SDV+10(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD11 = 'X' AND <ZB4>-SDV+11(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD12 = 'X' AND <ZB4>-SDV+12(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD13 = 'X' AND <ZB4>-SDV+13(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD15 = 'X' AND <ZB4>-SDV+15(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDD18 = 'X' AND <ZB4>-SDV+18(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ENDIF.

    IF PSTDT01 = 'X' AND <ZB4>-STAB+1(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT02 = 'X' AND <ZB4>-STAB+2(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT03 = 'X' AND <ZB4>-STAB+3(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT04 = 'X' AND <ZB4>-STAB+4(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT05 = 'X' AND <ZB4>-STAB+5(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT06 = 'X' AND <ZB4>-STAB+6(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT07 = 'X' AND <ZB4>-STAB+7(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT08 = 'X' AND <ZB4>-STAB+8(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT09 = 'X' AND <ZB4>-STAB+9(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT10 = 'X' AND <ZB4>-STAB+10(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT11 = 'X' AND <ZB4>-STAB+11(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT12 = 'X' AND <ZB4>-STAB+12(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT13 = 'X' AND <ZB4>-STAB+13(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT15 = 'X' AND <ZB4>-STAB+15(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ELSEIF PSTDT18 = 'X' AND <ZB4>-STAB+18(1) = 'X'.
      <ZB4>-NOTSELECTED  = ''.
    ENDIF.

*   GET TABLE FIELDS
    PERFORM GETTABLEFIELDS USING
                            <ZB4>-TABNAME
                            <ZB4>-FLDLIST.

*   SHARED

    IF <ZB4>-NOTEXIST = '' AND <ZB4>-NOTSELECTED = ''.
      PERFORM GENDYNAMICSHARED CHANGING
                                NUMCHAR.
    ELSE.
      NUMCHAR = 0.
    ENDIF.

*   SIZE - TOOBIG FLAG

    IF <ZB4>-NOTEXIST = '' AND <ZB4>-NOTSELECTED = ''.
      IF <ZB4>-LIMIT = MAXLIMIT.
        NUMREC = 0.
      ELSEIF <ZB4>-LANGFIELD <> '' AND <ZB4>-TABNAME <> 'AGR_PROF'.
        CONCATENATE <ZB4>-LANGFIELD '= SY-LANGU'
                    INTO CONDFLD
                    SEPARATED BY SPACE.
        IF <ZB4>-GENERATE = 'WHERE'.
          PERFORM GENVARCODE USING <ZB4>-TABNAME CHANGING WHEREEXPR.

          CONCATENATE CONDFLD 'AND' WHEREEXPR
                      INTO CONDFLD
                      SEPARATED BY SPACE.

          SELECT         COUNT( * )
                   INTO  (NUMREC)
                   FROM  (<ZB4>-TABNAME)
                   WHERE (CONDFLD).
        ELSE.
          SELECT         COUNT( * )
                   INTO  (NUMREC)
                   FROM  (<ZB4>-TABNAME)
                   WHERE (CONDFLD).
        ENDIF.
      ELSE.
        IF <ZB4>-GENERATE = 'WHERE'.
          PERFORM GENVARCODE USING <ZB4>-TABNAME CHANGING WHEREEXPR.

          SELECT        COUNT( * )
                   INTO (NUMREC)
                   FROM (<ZB4>-TABNAME)
                  WHERE (WHEREEXPR).
        ELSE.
           SELECT       COUNT( * )
                   INTO (NUMREC)
                   FROM (<ZB4>-TABNAME).
        ENDIF.
      ENDIF.

      CALCBYTE = NUMREC * NUMCHAR / 1024 / 1024.

      IF CALCBYTE > <ZB4>-LIMIT.
        WEXP-DOWNLOAD = 'N'.
        <ZB4>-TOOBIG = 'Y'.
      ELSE.
        WEXP-DOWNLOAD = 'Y'.
      ENDIF.
    ELSE.
       WEXP-DOWNLOAD = ''.
    ENDIF.

    IF WEXP-DOWNLOAD = 'N'.
      NNUM = CALCBYTE.
      TXTSTR = NNUM.
      SHIFT TXTSTR LEFT DELETING LEADING '0'.
      NNUM = NUMREC.
      TXT2STR = NNUM.
      SHIFT TXT2STR LEFT DELETING LEADING '0'.
      SHIFT <ZB4>-LIMIT LEFT DELETING LEADING '0'.
      CONCATENATE 'Information:' <ZB4>-TABNAME 'table'
                  'was not selected for download due to size'
                  TXTSTR 'MB ( Limit' <ZB4>-LIMIT ' MB /'
                                      TXT2STR ' Recs).'
                  INTO CONCAT
                  SEPARATED BY SPACE.
      CONDENSE CONCAT.
      PERFORM EXPB1REC USING 'DYNFORMCHK' 'I' 'C' CONCAT.
    ENDIF.

    PERFORM GENCONSTFORM.

    PERFORM GENDYNAMICFORM USING
                            <ZB4>-FTYPE
                            <ZB4>-TABNAME
                            <ZB4>-TABTEXT
                            <ZB4>-LANGFIELD
                            <ZB4>-TABNAMETEXT
                            <ZB4>-LANGFIELDTEXT
                            <ZB4>-LIMIT
                            <ZB4>-GENERATE
                            <ZB4>-MANDATORY
                            <ZB4>-CLIENT
                            <ZB4>-FFSD
                            <ZB4>-FAGF
                            <ZB4>-SDV
                            <ZB4>-STAB
                            <ZB4>-TOOBIG
                            <ZB4>-NOTEXIST
                            <ZB4>-NOTSELECTED
                            <ZB4>-FLDLIST.

    PERFORM GENABAP.

    IF GENERROR = ABAP_TRUE.
*     GENERATE BLANK REPORT.
      PERFORM GENCONSTSTART.

*     SHARED
      IF <ZB4>-NOTEXIST = '' AND <ZB4>-NOTSELECTED = ''.
        PERFORM GENDYNAMICSHARED CHANGING
                                  NUMCHAR.
      ENDIF.

      PERFORM GENCONSTFORM.

      PERFORM GENDYNAMICFORM USING
                              <ZB4>-FTYPE
                              <ZB4>-TABNAME
                              <ZB4>-TABTEXT
                              <ZB4>-LANGFIELD
                              <ZB4>-TABNAMETEXT
                              <ZB4>-LANGFIELDTEXT
                              <ZB4>-LIMIT
                              <ZB4>-GENERATE
                              <ZB4>-MANDATORY
                              <ZB4>-CLIENT
                              <ZB4>-FFSD
                              <ZB4>-FAGF
                              <ZB4>-SDV
                              <ZB4>-STAB
                              <ZB4>-TOOBIG
                              <ZB4>-NOTEXIST
                              <ZB4>-NOTSELECTED
                              <ZB4>-FLDLIST.

      PERFORM GENABAP.
    ENDIF.

*   Clear table fields - not required anymore
    CLEAR IDD03L.
    REFRESH IDD03L.

    PERFORM SUBMITTEMP.
  ENDLOOP.
ENDFORM.                    "EXPDYNAMIC

