  PERFORM C1 USING '    CYEAR = CYEAR - 1.'.
  PERFORM C1 USING '    SMONTH = 12 + SMONTH - CMONTH.'.
  PERFORM C1 USING '  ELSE.'.
  PERFORM C1 USING '    SMONTH = SMONTH - CMONTH.'.
  PERFORM C1 USING '  ENDIF.'.
