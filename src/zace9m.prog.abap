    PERFORM C1 USING '                  W_PERIODSTRT'.
    PERFORM C1 USING '             INTO TXTSTR'.
    PERFORM C1 USING '        SEPARATED BY SPACE.'.
    PERFORM C1 USING '      PERFORM EXPB1REC USING ''DLD'' ''I'''.
    PERFORM C1 USING '                               ''C'' TXTSTR.'.
    PERFORM C1 USING ''.
    PERFORM C1 USING '      PERFORM STARTDOWNLOAD.'.
    PERFORM C1 USING ''.
    PERFORM C1 USING '      PERFORM EXPSUBTLD USING-'.
