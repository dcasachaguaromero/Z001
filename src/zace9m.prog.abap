*      Form  AUTALLLEVEL                                              *
*---------------------------------------------------------------------*
FORM AUTALLLEVEL USING MAINAUT CHECKAUT FUNCINC
                 CHANGING CURLEVEL RESEXIT.
  DATA: SUBC TYPE TRDIR-SUBC
       ,PNAME TYPE TFDIR-PNAME
       ,INCLUDE TYPE TFDIR-INCLUDE
       ,POS TYPE I
       ,POS2 TYPE I
       ,NEXTLEVEL TYPE I
       ,CLCLASS(200) TYPE C
       ,CLMETHOD(200) TYPE C
       ,METHODCODE(200) TYPE C
       ,CHECKVAL(50) TYPE C
       .

  CHECKVAL = CHECKAUT.

  IF CHECKVAL CS '=>'.
    CLCLASS = CHECKVAL+0(SY-FDPOS).
    SY-FDPOS = SY-FDPOS + 2.
    CLMETHOD = CHECKVAL+SY-FDPOS.
**add comment ini
    SYSTEM-CALL QUERY METHOD CLMETHOD
                      OF CLASS CLCLASS
                      INCLUDE INTO METHODCODE."#EC CI_SYSTEMCALL
**add comment fin
    WAUTTESTING-TYPE = 'Method'.
    INSERT WAUTTESTING INTO ZAUTTESTING INDEX AUTINDEX.

    IF METHODCODE = ''.
      RESEXIT = 'Y'.
      EXIT.
    ENDIF.

    NEXTLEVEL = CURLEVEL + 1.
    PERFORM AUTEVAL USING MAINAUT METHODCODE NEXTLEVEL ''.
    RESEXIT = 'Y'.
    EXIT.
  ELSEIF CHECKVAL CS '->'.
    CLCLASS = CHECKVAL+0(SY-FDPOS).
    SY-FDPOS = SY-FDPOS + 2.
    CLMETHOD = CHECKVAL+SY-FDPOS.
**add comment ini
    SYSTEM-CALL QUERY METHOD CLMETHOD
                      OF CLASS CLCLASS
                      INCLUDE INTO METHODCODE."#EC CI_SYSTEMCALL
**add comment fin
    IF METHODCODE = ''.
      RESEXIT = 'Y'.
      EXIT.
    ENDIF.

    WAUTTESTING-TYPE = 'Method'.
    INSERT WAUTTESTING INTO ZAUTTESTING INDEX AUTINDEX.

    NEXTLEVEL = CURLEVEL + 1.
    PERFORM AUTEVAL USING MAINAUT METHODCODE NEXTLEVEL ''.
    RESEXIT = 'Y'.
    EXIT.
  ENDIF.

*
*  EVALUATING REPORTS
*
  SELECT SINGLE
         SUBC
    INTO SUBC
    FROM TRDIR
   WHERE NAME = CHECKVAL.

  IF SY-SUBRC = 0.
    IF SUBC = 'I'.
      IF FUNCINC = 'F'.
        WAUTTESTING-TYPE = 'Func. Include'.
      ELSE.
        WAUTTESTING-TYPE = 'Include'.
      ENDIF.
    ELSE.
      IF CURLEVEL = 0.
        WAUTTESTING-TYPE = 'Selected Program'.
      ELSE.
        WAUTTESTING-TYPE = 'Program'.
      ENDIF.
    ENDIF.
    INSERT WAUTTESTING INTO ZAUTTESTING INDEX AUTINDEX.
  ELSE.
    SELECT SINGLE
           PNAME
           INCLUDE
      INTO (PNAME
           ,INCLUDE
           )
      FROM TFDIR
     WHERE FUNCNAME = CHECKVAL.
    IF SY-SUBRC = 0.
      WAUTTESTING-TYPE = 'Function Module'.
      INSERT WAUTTESTING INTO ZAUTTESTING INDEX AUTINDEX.
      SEARCH PNAME+1 FOR '/'.
      IF SY-SUBRC = 0.
        POS = SY-FDPOS + 2.
        POS2 = SY-FDPOS + 5.
        CONCATENATE PNAME+0(POS) PNAME+POS2 'U' INCLUDE
                    INTO CHECKVAL.
      ELSE.
        CONCATENATE PNAME+3 'U' INCLUDE
                    INTO CHECKVAL.
      ENDIF.
      NEXTLEVEL = CURLEVEL + 1.
      PERFORM AUTEVAL USING MAINAUT CHECKVAL NEXTLEVEL 'F'.
      RESEXIT = 'Y'.
      EXIT.
    ELSE.
      WAUTTESTING-TYPE = 'Unknown Object 2'.
      READ TABLE ZAUTTESTING TRANSPORTING NO FIELDS
        WITH TABLE KEY AUTID = WAUTTESTING-AUTID.
*     Entry with Key may already exist
      IF SY-SUBRC NE 0. "Key not found. Safe to insert
        INSERT WAUTTESTING INTO ZAUTTESTING INDEX AUTINDEX.
        RESEXIT = 'Y'.
      ENDIF.
      EXIT.
    ENDIF.
  ENDIF.
ENDFORM.                    "AUTALLLEVEL

*---------------------------------------------------------------------*
*      Form  AUTLOOP                                                  *
*---------------------------------------------------------------------*
FORM AUTLOOP TABLES CLINES
             USING  LOOPTYPE MAINAUT CHECKAUT CURLEVEL
                    SEARCHSTR OBJCT TTEXT.
  DATA: CLIN TYPE STRING
       ,CLIN2 TYPE STRING
       ,LSPOS TYPE I
       ,LEPOS TYPE I
       ,LSSUBPOS TYPE I
       ,PQUOTE TYPE I
       ,PFOUND TYPE I
       ,LEND TYPE I
       ,RES TYPE I
       ,NEXTLEVEL TYPE I
       ,NEXTAUT(50) TYPE C
       ,FOUNDAUT1(50) TYPE C
       ,FOUNDAUT2(50) TYPE C
       ,FOUNDREF(50) TYPE C
       ,AUTID(50) TYPE C
       .

  SEARCH CLINES FOR SEARCHSTR.

  WHILE SY-SUBRC = 0.
    LSPOS = SY-TABIX + 1.

    READ TABLE CLINES INTO CLIN INDEX SY-TABIX.
    CONDENSE CLIN.

    IF STRLEN( CLIN ) = 0.
      "Nothing
    ELSEIF CLIN(1) = '*'.
      "Nothing
    ELSE.
      PQUOTE = 9999.
      FIND FIRST OCCURRENCE OF '"' IN CLIN MATCH OFFSET PQUOTE.
      FIND FIRST OCCURRENCE OF SEARCHSTR IN CLIN MATCH OFFSET PFOUND.

      IF PQUOTE < PFOUND.
        "Nothing
      ELSE.
        IF LOOPTYPE = 'OBJ'.

               " PROCESSING OF OBJECT

          CLEAR WAUTINCOBJ.
          WAUTINCOBJ-INCID = CHECKAUT.
          WAUTINCOBJ-OBJCT = OBJCT.
          WAUTINCOBJ-TTEXT = TTEXT.
          APPEND WAUTINCOBJ TO ZAUTINCOBJ.

          LSSUBPOS = LSPOS.
          WHILE LSSUBPOS > 0.
            CLEAR WAUTCODE.
            WAUTCODE-INCID = CHECKAUT.
            WAUTCODE-CODE = CLIN.
            CONDENSE WAUTCODE-CODE.
            APPEND WAUTCODE TO ZAUTCODE.

            FIND FIRST OCCURRENCE OF '.' IN WAUTCODE-CODE.
            IF SY-SUBRC = 0.
               LSSUBPOS = 0.
            ELSE.
              READ TABLE CLINES INTO CLIN INDEX LSSUBPOS.
              LSSUBPOS = LSSUBPOS + 1.
            ENDIF.
          ENDWHILE.

        ELSE.
          PERFORM AUTLINECHECK USING CLIN SEARCHSTR
                               CHANGING FOUNDAUT1 FOUNDAUT2.

          IF FOUNDAUT1 <> ''.
            NEXTAUT = ''.

            IF SEARCHSTR = '=>'.
               " PROCESSING OF =>

              SELECT COUNT(*)
                FROM TMDIR
               WHERE CLASSNAME = FOUNDAUT1.

              IF SY-SUBRC = 0.
                CONCATENATE FOUNDAUT1 FOUNDAUT2
                       INTO NEXTAUT.
              ENDIF.

            ELSEIF SEARCHSTR CS '->'.

               " PROCESSING OF ->

              SEARCH CLINES FOR FOUNDAUT1.

              WHILE SY-SUBRC = 0 AND NEXTAUT = ''.
                LEPOS = SY-TABIX + 1.

                READ TABLE CLINES INTO CLIN INDEX SY-TABIX.
                CONDENSE CLIN.

                IF STRLEN( CLIN ) = 0.
                  "Nothing
                ELSEIF CLIN(1) = '*'.
                  "Nothing
                ELSE.
                  PQUOTE = 9999.
                  FIND FIRST OCCURRENCE OF '"' IN CLIN
                             MATCH OFFSET PQUOTE.
                  FIND FIRST OCCURRENCE OF SEARCHSTR IN CLIN
                             MATCH OFFSET PFOUND.

                  IF PQUOTE < PFOUND.
                    "Nothing
                  ELSE.
                    LEND = STRLEN( CLIN ) - 1.
                    IF CLIN+LEND(1) <> '.'.
                      READ TABLE CLINES INTO CLIN2 INDEX LEPOS.
                      CONCATENATE CLIN CLIN2 INTO CLIN
                                  SEPARATED BY SPACE.
                      CONDENSE CLIN.
                    ENDIF.

                    CONCATENATE FOUNDAUT1 'TYPE REF TO' INTO FOUNDREF
                                                SEPARATED BY SPACE.

                    IF CLIN CS FOUNDREF.
                      CLIN = CLIN+SY-FDPOS.
                      LEND = STRLEN( FOUNDREF ) + 1.
                      CLIN = CLIN+LEND.
                      TRANSLATE CLIN USING ' .'.
                      TRANSLATE CLIN USING ',.'.
                      TRANSLATE CLIN USING '(.'.
                      CONDENSE CLIN.
                      IF STRLEN( CLIN ) > 1 AND CLIN CS '.'.
                        IF SY-FDPOS > 0.
                          CLIN = CLIN(SY-FDPOS).
                          TRANSLATE CLIN TO UPPER CASE.
                          SELECT COUNT(*)
                            FROM TMDIR
                           WHERE CLASSNAME = CLIN.
                          IF SY-SUBRC = 0.
                            CONCATENATE CLIN FOUNDAUT2 INTO NEXTAUT.
                          ENDIF.
                        ENDIF.
                      ENDIF.
                    ENDIF.
                  ENDIF.
                ENDIF.

                IF NEXTAUT = ''.
                  SEARCH CLINES FOR FOUNDAUT1
                         STARTING AT LEPOS.
                ENDIF.
              ENDWHILE.

            ELSE.

               " PROCESSING OF INCLUDE ETC.

              NEXTAUT = FOUNDAUT1.
            ENDIF.

            IF NEXTAUT <> ''.
              CONCATENATE MAINAUT '-' NEXTAUT
                     INTO AUTID.

              READ TABLE ZAUTTESTING WITH TABLE KEY AUTID = AUTID
                   INTO WAUTTESTING.

              IF SY-SUBRC = 4 OR SY-SUBRC = 8.
                NEXTLEVEL = CURLEVEL + 1.
                PERFORM AUTEVAL USING MAINAUT NEXTAUT NEXTLEVEL ''.
              ENDIF.
            ENDIF.
          ENDIF.
        ENDIF.
      ENDIF.
    ENDIF.

    SEARCH CLINES FOR SEARCHSTR
           STARTING AT LSPOS.
  ENDWHILE.

ENDFORM.                    "AUTLOOP

*---------------------------------------------------------------------*
*      Form  AUTLINECHECK                                             *
*---------------------------------------------------------------------*
FORM AUTLINECHECK USING CLINE SEARCHSTR CHANGING FOUNDNAME1 FOUNDNAME2.
  DATA: LINCOL TYPE I
       ,PQUOTE TYPE I
       ,PFOUND TYPE I
       ,POSF TYPE I
       ,TEMPSTR TYPE STRING
       ,FINDSTR(1) TYPE C
       .

  FOUNDNAME1 = ''.
  FOUNDNAME2 = ''.

  TEMPSTR = CLINE.

  TRANSLATE TEMPSTR TO UPPER CASE.
  CONDENSE TEMPSTR.

  IF STRLEN( TEMPSTR ) = 0.
    EXIT.
  ELSEIF TEMPSTR(1) = '*'.
    EXIT.
  ELSE.
    PQUOTE = 9999.
    FIND FIRST OCCURRENCE OF '"' IN TEMPSTR MATCH OFFSET PQUOTE.
    FIND FIRST OCCURRENCE OF SEARCHSTR IN TEMPSTR MATCH OFFSET PFOUND.

    IF PQUOTE < PFOUND.
      EXIT.
    ENDIF.
  ENDIF.

  IF SEARCHSTR = '=>' OR SEARCHSTR = '->'.
    TRANSLATE TEMPSTR USING ' .'.
    TRANSLATE TEMPSTR USING '(.'.
    TRANSLATE TEMPSTR USING ').'.
    TRANSLATE TEMPSTR USING ',.'.

    FIND FIRST OCCURRENCE OF SEARCHSTR IN TEMPSTR MATCH OFFSET POSF.

    WHILE POSF < STRLEN( TEMPSTR ).
      IF TEMPSTR+POSF(1) = '.'.
        TEMPSTR = TEMPSTR+0(POSF).
        POSF = 9999.
      ELSE.
        POSF = POSF + 1.
      ENDIF.
    ENDWHILE.

    FIND FIRST OCCURRENCE OF SEARCHSTR IN TEMPSTR MATCH OFFSET POSF.

    WHILE POSF >= 0.
      IF TEMPSTR+POSF(1) = '.'.
        POSF = POSF + 1.
        TEMPSTR = TEMPSTR+POSF.
        POSF = -1.
      ELSE.
        POSF = POSF - 1.
      ENDIF.
    ENDWHILE.

    FIND FIRST OCCURRENCE OF SEARCHSTR IN TEMPSTR MATCH OFFSET POSF.
    FOUNDNAME1 = TEMPSTR(POSF).
    FOUNDNAME2 = TEMPSTR+POSF.
    CONDENSE FOUNDNAME1.
    CONDENSE FOUNDNAME2.
    IF STRLEN( FOUNDNAME1 ) = 0 OR STRLEN( FOUNDNAME2 ) < 3.
      FOUNDNAME1 = ''.
      FOUNDNAME2 = ''.
    ENDIF.
  ELSE.
    "OTHERS LIKE INCLUDE ETC.

    "Check line starts with search string
    LINCOL = STRLEN( SEARCHSTR ).
    IF STRLEN( TEMPSTR ) < LINCOL.
      EXIT.
    ENDIF.
    IF TEMPSTR+0(LINCOL) <> SEARCHSTR.
      EXIT.
    ENDIF.
    TEMPSTR = TEMPSTR+LINCOL.

    "Check space after search string
    IF STRLEN( TEMPSTR ) = 0.
      EXIT.
    ENDIF.
    FINDSTR = TEMPSTR+0(1).
    IF FINDSTR <> SPACE.
      EXIT.
    ENDIF.
    TEMPSTR = TEMPSTR+1.

    "Get string after search
    TRANSLATE TEMPSTR USING ' .'.
    IF TEMPSTR CA '#".,('.
      TEMPSTR = TEMPSTR+0(SY-FDPOS).
    ENDIF.
    CONDENSE TEMPSTR.

    IF TEMPSTR = 'STRUCTURE' OR
       TEMPSTR = '=' OR
       TEMPSTR = 'LIKE' OR
       TEMPSTR = 'INTO' OR
       TEMPSTR = '' OR
       TEMPSTR = 'TYPE'.
      EXIT.
    ENDIF.

    IF SEARCHSTR = 'CALL FUNCTION'.
      IF TEMPSTR+0(1) <> ''''.
        EXIT.
      ENDIF.
      LINCOL = STRLEN( TEMPSTR ) - 1.
      IF TEMPSTR+LINCOL(1) <> ''''.
        EXIT.
      ENDIF.
      LINCOL = LINCOL - 1.
      TEMPSTR = TEMPSTR+1(LINCOL).
    ENDIF.

    FOUNDNAME1 = TEMPSTR.
  ENDIF.
ENDFORM.


