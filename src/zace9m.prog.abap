FORM EXPPST.
  DATA: EXFLAG(1) TYPE C.
  REFRESH : T_SELECT,
            T_WHERE.

  WEXP-LOCATION = 'ACEPST'.
  WEXP-FTYPE = 'W'.
  WEXP-TABNAME = 'ACEBKPF'.
  WEXP-TABTEXT = 'Int. table Posting Header'.
  WEXP-SCHEMA = 'NA'.
  WEXP-QUERIES = 'N'.
  WEXP-GEN = ''.
  WEXP-FLDLST = ''.

  PERFORM CHECKTABEXISTS USING 'BKPF' CHANGING EXFLAG.
  CHECK EXFLAG = 'X'.

  PERFORM PSTPOPULATE.

  PERFORM GENCONSTSTART.
  PERFORM GENPSTSHARED.
  PERFORM GENCONSTFORM.
  PERFORM GENPSTFORM.
  PERFORM GENABAP.

  EXPORT SEL01 SEL02 SEL03 SEL04 SEL05
         SEL06 SEL07 SEL08 SEL09 SEL10
         SEL11 SEL12 SEL13 SEL14 SEL15
         TO MEMORY ID MEMID.

  WEXP-DOWNLOAD = 'Y'.
  PERFORM SUBMITTEMP.

  DELETE FROM MEMORY ID MEMID.

  PERFORM EXECCOMMIT USING 'PST-END'.
ENDFORM.                    " EXPPST

