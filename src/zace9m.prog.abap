    PERFORM C1 USING '                        W_PERIODSTRT.'.
    PERFORM C1 USING ''.
    PERFORM C1 USING '      PERFORM ENDDOWNLOAD.'.
    PERFORM C1 USING ''.
    PERFORM C3 USING '      IF RECCOUNT > ' NUMVAL2 '.'.
