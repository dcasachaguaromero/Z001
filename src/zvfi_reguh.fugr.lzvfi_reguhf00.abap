FORM DB_UPD_ZVFI_REGUH .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO ZVFI_REGUH.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_ZVFI_REGUH-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM REGUH WHERE
  LAUFD = ZVFI_REGUH-LAUFD AND
  LAUFI = ZVFI_REGUH-LAUFI AND
  XVORL = ZVFI_REGUH-XVORL AND
  ZBUKR = ZVFI_REGUH-ZBUKR AND
  LIFNR = ZVFI_REGUH-LIFNR AND
  KUNNR = ZVFI_REGUH-KUNNR AND
  EMPFG = ZVFI_REGUH-EMPFG AND
  VBLNR = ZVFI_REGUH-VBLNR .
    IF SY-SUBRC = 0.
    DELETE REGUH .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM REGUH WHERE
  LAUFD = ZVFI_REGUH-LAUFD AND
  LAUFI = ZVFI_REGUH-LAUFI AND
  XVORL = ZVFI_REGUH-XVORL AND
  ZBUKR = ZVFI_REGUH-ZBUKR AND
  LIFNR = ZVFI_REGUH-LIFNR AND
  KUNNR = ZVFI_REGUH-KUNNR AND
  EMPFG = ZVFI_REGUH-EMPFG AND
  VBLNR = ZVFI_REGUH-VBLNR .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR REGUH.
    ENDIF.
REGUH-MANDT =
ZVFI_REGUH-MANDT .
