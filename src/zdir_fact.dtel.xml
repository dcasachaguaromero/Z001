      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;DEFINITION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Name der Straße als Bestandteil der Adresse.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Straßenname wird in einem weiteren Datenbankfeld (redundant) in</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Großbuchstaben gespeichert, was für Suchhilfen benutzt wird.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es gibt weitere Felder für Adreßangaben, die über oder unter der Straße</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>gedruckt werden können. Siehe dazu &lt;DS:TX.ADDRESS_STREET_FIELDS&gt;Drucken</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>der Straßenadresse&lt;/&gt;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Hausnummer und weitere Ergänzungen werden üblicherweise in eigenen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Feldern gepflegt. Siehe &lt;DS:TX.ADDRESS_HOUSE_NUMBER_RULES&gt;Aufbereitung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>der Straßenzeile&lt;/&gt;.</TDLINE>
      </TLINE>
     </LINES>
    </item>
