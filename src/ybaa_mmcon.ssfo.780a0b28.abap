
DATA LS_T027B TYPE T027B.
DATA LS_T027A TYPE T027A.
CLEAR GS_V027A.
IF NOT <FS>-EVERS IS INITIAL.
* BEGIN. 07-07-2026 - ATC - ATC-01
* OLD CODE
*SELECT SINGLE * FROM T027A INTO LS_T027A
*WHERE EVERS = <FS>-EVERS.
*
* NEW CODE
SELECT *
UP TO 1 ROWS  FROM T027A INTO LS_T027A
WHERE EVERS = <FS>-EVERS ORDER BY PRIMARY KEY.

ENDSELECT.
* END. 07-07-2026 - ATC - ATC-01
IF SY-SUBRC = 0.
GS_V027A-EVERS = LS_T027A-EVERS.
GS_V027A-EVDRU = LS_T027A-EVDRU.
ENDIF.

* BEGIN. 07-07-2026 - ATC - ATC-01
* OLD CODE
*SELECT SINGLE * FROM T027B INTO LS_T027B
*WHERE EVERS = <FS>-EVERS
*AND SPRAS = GV_LANGUAGE.
*
* NEW CODE
SELECT *
UP TO 1 ROWS  FROM T027B INTO LS_T027B
WHERE EVERS = <FS>-EVERS
AND SPRAS = GV_LANGUAGE ORDER BY PRIMARY KEY.

ENDSELECT.
* END. 07-07-2026 - ATC - ATC-01
IF SY-SUBRC = 0.
GS_V027A-EVTXT = LS_T027B-EVTXT.
ENDIF.
ENDIF.




























