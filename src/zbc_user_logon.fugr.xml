  <asx:values>
   <AREAT>Verificar Acceso del usuario SAP</AREAT>
   <INCLUDES>
    <SOBJ_NAME>LZBC_USER_LOGONTOP</SOBJ_NAME>
    <SOBJ_NAME>SAPLZBC_USER_LOGON</SOBJ_NAME>
   </INCLUDES>
   <FUNCTIONS>
    <item>
     <FUNCNAME>ZBC_USER_LOGON</FUNCNAME>
     <REMOTE_CALL>R</REMOTE_CALL>
     <SHORT_TEXT>Verifica el acceso del Usuario de SAP</SHORT_TEXT>
     <IMPORT>
      <RSIMP>
       <PARAMETER>USUARIO</PARAMETER>
       <TYP>RSYST-BNAME</TYP>
      </RSIMP>
      <RSIMP>
       <PARAMETER>PASWORD</PARAMETER>
       <TYP>RSYST-BCODE</TYP>
      </RSIMP>
     </IMPORT>
     <EXPORT>
      <RSEXP>
       <PARAMETER>MENSAJE</PARAMETER>
       <TYP>CHAR40</TYP>
      </RSEXP>
     </EXPORT>
     <DOCUMENTATION>
      <RSFDO>
       <PARAMETER>USUARIO</PARAMETER>
       <KIND>P</KIND>
       <STEXT>Nombre de usuario</STEXT>
      </RSFDO>
      <RSFDO>
       <PARAMETER>PASWORD</PARAMETER>
       <KIND>P</KIND>
       <STEXT>Clave de acceso del usuario</STEXT>
      </RSFDO>
      <RSFDO>
       <PARAMETER>MENSAJE</PARAMETER>
       <KIND>P</KIND>
       <STEXT>Campo character, longitud 40</STEXT>
      </RSFDO>
     </DOCUMENTATION>
    </item>
   </FUNCTIONS>
