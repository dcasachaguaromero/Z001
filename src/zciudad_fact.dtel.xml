      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Ortsname als Bestandteil der Adresse.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Ortsname wird in einem weiteren Datenbankfeld (redundant) in</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Großbuchstaben gespeichert, was für Suchhilfen benutzt wird.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Wenn die &lt;DS:RE.SAPLSZAR&gt;Postalische Regionalstruktur&lt;/&gt; (&apos;Ortsdatei&apos;)</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>aktiv ist, wird der Ortsname gegen die in der Regionalstruktur</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>definierten &lt;DS:RE.SAPLSZRC&gt;Orte&lt;/&gt; geprüft.</TDLINE>
      </TLINE>
     </LINES>
