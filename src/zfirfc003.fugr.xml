      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es werden allgemeine Daten, eine Tabelle der Bankdaten und, wenn ein</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Buchungskreis angegeben wurde, buchungskreisspezifische Daten</TDLINE>
      </TLINE>
