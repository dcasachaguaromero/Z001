      <TDVERSION>00002</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;DESCRIPTION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Este report copia números de cheque a un campo seleccionado de los</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>documentos de pago correspondientes. El número de cheque se puede</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>copiar, por ejemplo, al campo &quot;Número de documento de referencia&quot; del</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>documento de pago, de manera que el cheque se pueda asignar a partir</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>del documento de pago.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Esta referencia de números de cheque se marca en la tabla de medios de</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>pago, de forma que los números de cheque ya copiados a los documentos</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>de pago correspondientes ya no se tengan más en cuenta en este report.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Si se modifica un documento de pago, se reinicializará el</TDLINE>
      </TLINE>
      <TLINE>
