     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZRFSEPA02</TDNAME>
      <TDID>RE</TDID>
      <TDSPRAS>S</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00018</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;DESCRIPTION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>El report activa la gestión de partidas abiertas (PA) para una cuenta</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>de mayor y modifica adecuadamente los documentos contabilizados antes.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Estos se visualizan posteriormente como partidas abiertas. No se</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ejecutarán tareas de retoque en las partidas abiertas. En particular no</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>se registran posteriormente datos de compensación en los documentos</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>anulados.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;PRECONDITION&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>No deben haberse archivado aún partidas de dicha cuenta.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>&lt;ZH&gt;Atención:&lt;/&gt; Esto debe garantizarlo Ud. mismo a través de medidas</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>organizativas. Algunas cuentas de mayor no deben gestionarse por</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>partida abiertas. A estas pertenecen especialmente las cuentas que</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>utilizan procesos automáticos en la determinación de cuentas (por</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ejemplo, cuentas para las operaciones MVA, VVA o cuentas en las que se</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>contabilizan asientos para la clase de cuenta M).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>&lt;ZH&gt;Atención:&lt;/&gt;  Verifique primero si la cuenta de mayor en cuestión</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>puede realmente gestionarse por partidas abiertas.</TDLINE>
      </TLINE>
